{
  "name": "mokelay-server",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nitro dev --host 127.0.0.1 --port 8787",
    "build": "nitro build",
    "preview": "nitro preview --host 127.0.0.1 --port 8787",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "deploy:check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@adonisjs/hash": "^9.1.1",
    "drizzle-orm": "^0.44.5",
    "h3": "^1.15.4",
    "nitropack": "^2.12.9",
    "openai": "^6.36.0",
    "postgres": "^3.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
