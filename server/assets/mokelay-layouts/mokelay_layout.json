              "source": "globalSetting",
              "key": "theme"
            },
            "options": [
              {
                "label": { "$i18n": { "zh-CN": "浅色", "en-US": "Light" } },
                "value": "light"
              },
              {
                "label": { "$i18n": { "zh-CN": "深色", "en-US": "Dark" } },
                "value": "dark"
              }
            ]
          },
          {
            "id": "language",
            "type": "select",
            "label": { "$i18n": { "zh-CN": "语言", "en-US": "Language" } },
            "binding": {
              "source": "globalSetting",
              "key": "language"
            },
            "options": [
              {
                "label": { "$i18n": { "zh-CN": "中文", "en-US": "中文" } },
                "value": "zh"
              },
              {
                "label": { "$i18n": { "zh-CN": "English", "en-US": "English" } },
                "value": "en"
              }
            ]
          }
        ]
      },
