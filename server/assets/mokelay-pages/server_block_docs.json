{
  "uuid": "server_block_docs",
  "subPage": true,
  "quotes": ["server_docs"],
  "dependencies": [],
  "name": "服务端 Block 文档",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "server-block-docs-title",
      "type": "MHeading",
      "data": {
        "text": {
          "$i18n": {
            "zh-CN": "服务端 Block 文档",
            "en-US": "Server Block Docs"
          }
        },
        "level": "1",
        "align": "left"
      }
    },
    {
      "id": "server-block-docs-table",
      "type": "MAdvanceTable",
      "data": {
        "index": true,
        "selection": false,
        "showPageBreak": true,
        "columns": [
          {
            "columnName": "Function",
            "fieldVariable": "function_name",
            "fieldDataType": "string",
            "width": 190,
            "fixed": "left",
            "columnContent": [
              {
                "id": "server-block-docs-col-function",
                "type": "paragraph",
                "data": {
                  "text": "{{function_name}}"
                }
              }
            ]
          },
          {
            "columnName": {
              "$i18n": {
                "zh-CN": "名称",
                "en-US": "Name"
              }
            },
            "fieldVariable": "display_name",
            "fieldDataType": "string",
            "width": 180,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-block-docs-col-name",
                "type": "paragraph",
                "data": {
                  "text": "{{display_name}}"
                }
              }
            ]
          },
          {
            "columnName": {
              "$i18n": {
                "zh-CN": "分类",
                "en-US": "Category"
              }
            },
            "fieldVariable": "category",
            "fieldDataType": "string",
            "width": 170,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-block-docs-col-category",
                "type": "paragraph",
                "data": {
                  "text": "{{category}} / {{source_kind}}"
                }
              }
            ]
          },
          {
            "columnName": {
              "$i18n": {
                "zh-CN": "数据源",
                "en-US": "Datasource"
              }
            },
            "fieldVariable": "requires_datasource",
            "fieldDataType": "boolean",
            "width": 100,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-block-docs-col-datasource",
                "type": "paragraph",
                "data": {
                  "text": "{{requires_datasource}}"
                }
              }
            ]
          },
          {
            "columnName": {
              "$i18n": {
                "zh-CN": "说明",
                "en-US": "Description"
              }
            },
            "fieldVariable": "description",
            "fieldDataType": "string",
            "width": 420,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-block-docs-col-description",
                "type": "paragraph",
                "data": {
                  "text": "{{description}}"
                }
              }
            ]
          },
          {
            "columnName": {
              "$i18n": {
                "zh-CN": "操作",
                "en-US": "Actions"
              }
            },
            "fieldVariable": "uuid",
            "fieldDataType": "string",
            "width": 112,
            "fixed": "right",
            "columnContent": [
              {
                "id": "server-block-docs-open-detail-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": {
                    "$i18n": {
                      "zh-CN": "查看详情",
                      "en-US": "View Details"
                    }
                  },
                  "variant": "secondary",
                  "align": "left",
                  "bare": true
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "server_block_docs_open_detail",
                        "action": "jump_url",
                        "alias": "查看服务端 Block 文档详情",
                        "inputs": {
                          "url": {
                            "template": "/#/server_block_doc_detail?uuid={{uuid}}"
                          }
                        },
                        "outputs": [],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ],
        "ds": {
          "type": "API",
          "domain": "mokelay",
          "path": "/api/mokelay/list_server_block_docs",
          "method": "GET",
          "headerData": [],
          "bodyData": [],
          "queryData": [
            {
              "key": "page",
              "value": {
                "mode": "variable",
                "blockId": "server-block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "page"
              }
            },
            {
              "key": "pageSize",
              "value": {
                "mode": "variable",
                "blockId": "server-block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "pageSize"
              }
            }
          ],
          "schemaSelections": [
            {
              "path": "data.docs[]",
              "label": "docs",
              "type": "array"
            },
            {
              "path": "data.pagination.page",
              "label": "page",
              "type": "number"
            },
            {
              "path": "data.pagination.pageSize",
              "label": "pageSize",
              "type": "number"
            },
            {
              "path": "data.pagination.total",
              "label": "total",
              "type": "number"
            }
          ],
          "matchingExternalFields": [
            {
              "label": "数据",
              "variable": "data",
              "type": "array",
              "matchFieldPath": "data.docs[]"
            },
            {
              "label": "页码",
              "variable": "page",
              "type": "number",
              "matchFieldPath": "data.pagination.page"
            },
            {
              "label": "每页数量",
              "variable": "pageSize",
              "type": "number",
              "matchFieldPath": "data.pagination.pageSize"
            },
            {
              "label": "总数",
              "variable": "total",
              "type": "number",
              "matchFieldPath": "data.pagination.total"
            }
          ]
        }
      }
    }
  ],
  "localeConfig": {
    "defaultLocale": "zh-CN",
    "supportedLocales": [
      "zh-CN",
      "en-US"
    ]
  }
}
