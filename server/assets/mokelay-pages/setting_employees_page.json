                        "alias": "确认结果",
                        "inputs": {
                          "value": {
                            "template": "{{actions['setting_employees_delete_confirm'].outputs.result}}"
                          }
                        },
                        "nodes": [
                          {
                            "uuid": "setting_employees_delete_confirm_true",
                            "alias": "确认",
                            "value": true,
                            "nextAction": "setting_employees_delete_execute_ds"
                          },
                          {
