{
  "uuid": "mokelay_list_page",
  "createdAt": "2026-06-20T12:42:39.437Z",
  "updatedAt": "2026-06-23T00:00:00.000Z",
  "name": "页面列表",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-list-page-create-button",
      "type": "MButton",
      "data": {
        "label": "创建页面",
        "variant": "primary",
        "align": "left",
        "action": {
          "type": "submit"
        }
      },
      "events": [
        {
          "event": "click",
          "actions": [
            {
              "uuid": "mokelay_list_page_open_create_dialog",
              "action": "open_dialog",
              "alias": "打开创建页面弹窗",
              "inputs": {
                "title": "创建页面",
                "pageUUID": "mokelay_create_page",
                "pageSource": "system"
              },
              "outputs": [
                "close_result"
              ],
              "nextAction": "mokelay_list_page_refresh_table"
            },
            {
              "uuid": "mokelay_list_page_refresh_table",
              "action": "call_block_method",
              "alias": "刷新页面列表",
              "inputs": {
                "blockId": "mokelay-list-page-table",
                "method": "refresh"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": null
            }
          ]
        }
      ]
    },
    {
      "id": "mokelay-list-page-action-toolbar",
      "type": "MActionToolbar",
      "data": {
        "align": "right",
        "size": "small",
        "mode": "inline",
        "buttons": [
          {
            "id": "batchDelete",
            "label": "批量删除",
            "variant": "danger",
            "disabled": true,
            "events": [
              {
                "event": "click",
                "actions": [
                  {
                    "uuid": "mokelay_list_page_batch_delete_confirm",
                    "action": "confirm",
                    "alias": "确认批量删除页面",
                    "inputs": {
                      "title": "确认批量删除页面",
                      "content": "确定要删除选中的页面吗？此操作不可恢复。"
                    },
                    "outputs": [
                      "result"
                    ],
                    "nextAction": "mokelay_list_page_batch_delete_confirm_route"
                  },
                  {
                    "uuid": "mokelay_list_page_batch_delete_confirm_route",
                    "action": "if_controller",
                    "type": "controller",
                    "alias": "确认结果",
                    "inputs": {
                      "value": {
                        "template": "{{actions['mokelay_list_page_batch_delete_confirm'].outputs.result}}"
                      }
                    },
                    "nodes": [
                      {
                        "uuid": "mokelay_list_page_batch_delete_confirm_true",
                        "alias": "确认",
                        "value": true,
                        "nextAction": "mokelay_list_page_batch_delete_get_selected_uuids"
                      },
                      {
                        "uuid": "mokelay_list_page_batch_delete_confirm_false",
                        "alias": "取消",
                        "value": false,
                        "nextAction": null
                      }
                    ]
                  },
                  {
                    "uuid": "mokelay_list_page_batch_delete_get_selected_uuids",
                    "action": "call_block_method",
                    "alias": "获取选中页面 UUID",
                    "inputs": {
                      "blockId": "mokelay-list-page-table",
                      "method": "getSelectedValues",
                      "field": "uuid"
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": "mokelay_list_page_batch_delete_execute_ds"
                  },
                  {
                    "uuid": "mokelay_list_page_batch_delete_execute_ds",
                    "action": "execute_ds",
                    "alias": "批量删除页面",
                    "inputs": {
                      "dsConfig": {
                        "type": "API",
                        "domain": "mokelay",
                        "path": "/api/mokelay/batch_delete_pages",
                        "method": "POST",
                        "headerData": [],
                        "bodyData": [
                          {
                            "key": "uuids",
                            "dataType": "array",
                            "value": {
                              "template": "{{actions['mokelay_list_page_batch_delete_get_selected_uuids'].outputs.returnData}}"
                            }
                          }
                        ],
                        "queryData": []
                      }
                    },
                    "outputs": [
                      "rawResponse"
                    ],
                    "nextAction": "mokelay_list_page_batch_delete_clear_selection"
                  },
                  {
                    "uuid": "mokelay_list_page_batch_delete_clear_selection",
                    "action": "call_block_method",
                    "alias": "清空选中页面",
                    "inputs": {
                      "blockId": "mokelay-list-page-table",
                      "method": "clearSelection"
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": "mokelay_list_page_batch_delete_refresh_table"
                  },
                  {
                    "uuid": "mokelay_list_page_batch_delete_refresh_table",
                    "action": "call_block_method",
                    "alias": "刷新页面列表",
                    "inputs": {
                      "blockId": "mokelay-list-page-table",
                      "method": "refresh"
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": null
                  }
                ]
              }
            ]
          },
          {
            "id": "batchPublish",
            "label": "批量发布",
            "variant": "secondary",
            "disabled": true,
            "events": []
          }
        ]
      },
      "events": []
    },
    {
      "id": "mokelay-list-page-table",
      "type": "MAdvanceTable",
      "data": {
        "index": false,
        "selection": true,
        "showPageBreak": true,
        "columns": [
          {
            "fixed": null,
            "width": null,
            "columnName": "uuid",
            "columnContent": [
              {
                "id": "mokelay-list-page-uuid",
                "type": "paragraph",
                "data": {
                  "text": "{{uuid}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "uuid"
          },
          {
            "fixed": null,
            "width": null,
            "columnName": "页面名称",
            "columnContent": [
              {
                "id": "mokelay-list-page-name",
                "type": "paragraph",
                "data": {
                  "text": "{{name}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "name"
          },
          {
            "fixed": null,
            "width": null,
            "columnName": "创建时间",
            "columnContent": [
              {
                "id": "mokelay-list-page-created-at",
                "type": "paragraph",
                "data": {
                  "text": "{{created_at}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "created_at"
          },
          {
            "fixed": null,
            "width": null,
            "columnName": "更新时间",
            "columnContent": [
              {
                "id": "mokelay-list-page-updated-at",
                "type": "paragraph",
                "data": {
                  "text": "{{updated_at}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "updated_at"
          },
          {
            "fixed": "right",
            "width": 168,
            "columnName": "操作",
            "columnContent": [
              {
                "id": "mokelay-list-page-open-button",
                "type": "MButton",
                "data": {
                  "label": "打开",
                  "variant": "secondary",
                  "align": "left",
                  "action": {
                    "type": "submit",
                    "uuid": "{{uuid}}"
                  }
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "mokelay_list_page_open_page",
                        "action": "jump_url",
                        "alias": "打开页面",
                        "inputs": {
                          "openNew": false,
                          "url": {
                            "template": "/#/pages/{{sourceBlock.data.action.uuid}}"
                          }
                        },
                        "nextAction": null
                      }
                    ]
                  }
                ]
              },
              {
                "id": "mokelay-list-page-delete-button",
                "type": "MButton",
                "data": {
                  "label": "删除",
                  "variant": "ghost",
                  "align": "left",
                  "action": {
                    "type": "submit",
                    "uuid": "{{uuid}}",
                    "name": "{{name}}"
                  }
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "mokelay_list_page_delete_confirm",
                        "action": "confirm",
                        "alias": "确认删除页面",
                        "inputs": {
                          "title": "确认删除页面",
                          "content": {
                            "template": "确定要删除页面「{{sourceBlock.data.action.name}}」吗？"
                          }
                        },
                        "outputs": [
                          "result"
                        ],
                        "nextAction": "mokelay_list_page_delete_confirm_route"
                      },
                      {
                        "uuid": "mokelay_list_page_delete_confirm_route",
                        "action": "if_controller",
                        "type": "controller",
                        "alias": "确认结果",
                        "inputs": {
                          "value": {
                            "template": "{{actions['mokelay_list_page_delete_confirm'].outputs.result}}"
                          }
                        },
                        "nodes": [
                          {
                            "uuid": "mokelay_list_page_delete_confirm_true",
                            "alias": "确认",
                            "value": true,
                            "nextAction": "mokelay_list_page_delete_execute_ds"
                          },
                          {
                            "uuid": "mokelay_list_page_delete_confirm_false",
                            "alias": "取消",
                            "value": false,
                            "nextAction": null
                          }
                        ]
                      },
                      {
                        "uuid": "mokelay_list_page_delete_execute_ds",
                        "action": "execute_ds",
                        "alias": "删除页面",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/delete_page_by_uuid",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": {
                                  "template": "{{sourceBlock.data.action.uuid}}"
                                }
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "mokelay_list_page_delete_refresh_table"
                      },
                      {
                        "uuid": "mokelay_list_page_delete_refresh_table",
                        "action": "call_block_method",
                        "alias": "刷新页面列表",
                        "inputs": {
                          "blockId": "mokelay-list-page-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "action"
          }
        ],
        "ds": {
          "type": "API",
          "domain": "mokelay",
          "path": "/api/mokelay/list_pages",
          "method": "GET",
          "headerData": [],
          "bodyData": [],
          "queryData": [
            {
              "key": "page",
              "value": {
                "mode": "variable",
                "blockId": "mokelay-list-page-table",
                "blockType": "MAdvanceTable",
                "variable": "page"
              }
            },
            {
              "key": "pageSize",
              "value": {
                "mode": "variable",
                "blockId": "mokelay-list-page-table",
                "blockType": "MAdvanceTable",
                "variable": "pageSize"
              }
            }
          ],
          "schemaSelections": [
            {
              "path": "data.pages[]",
              "type": "array",
              "label": "页面列表"
            },
            {
              "path": "data.pagination.page",
              "type": "number",
              "label": "当前页"
            },
            {
              "path": "data.pagination.pageSize",
              "type": "number",
              "label": "每页条数"
            },
            {
              "path": "data.pagination.total",
              "type": "number",
              "label": "总数"
            }
          ],
          "matchingExternalFields": [
            {
              "label": "列表数据",
              "variable": "data",
              "matchFieldPath": "data.pages[]"
            },
            {
              "label": "当前页",
              "variable": "page",
              "matchFieldPath": "data.pagination.page"
            },
            {
              "label": "每页条数",
              "variable": "pageSize",
              "matchFieldPath": "data.pagination.pageSize"
            },
            {
              "label": "总数",
              "variable": "total",
              "matchFieldPath": "data.pagination.total"
            }
          ]
        }
      },
      "events": [
        {
          "event": "havingSelectedRows",
          "actions": [
            {
              "uuid": "mokelay_list_page_enable_batch_delete",
              "action": "call_block_method",
              "alias": "启用批量删除",
              "inputs": {
                "blockId": "mokelay-list-page-action-toolbar",
                "method": "enable",
                "buttonId": "batchDelete"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": null
            }
          ]
        },
        {
          "event": "emptySelectedRow",
          "actions": [
            {
              "uuid": "mokelay_list_page_disable_batch_delete",
              "action": "call_block_method",
              "alias": "禁用批量删除",
              "inputs": {
                "blockId": "mokelay-list-page-action-toolbar",
                "method": "disable",
                "buttonId": "batchDelete"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": null
            }
          ]
        }
      ]
    }
  ]
}
