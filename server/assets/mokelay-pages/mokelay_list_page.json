                    "uuid": "mokelay_list_page_batch_delete_execute_ds",
                    "action": "execute_ds",
                    "alias": "批量删除页面",
                    "inputs": {
                      "dsConfig": {
                        "type": "API",
                        "domain": "mokelay",
                        "path": "/api/mokelay/batch_delete_pages",
                        "method": "POST",
                        "headerData": [],
                        "bodyData": [
                          {
                            "key": "uuids",
