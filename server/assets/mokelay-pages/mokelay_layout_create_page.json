{
  "uuid": "mokelay_layout_create_page",
  "subPage": true,
  "quotes": ["layouts"],
  "dependencies": [],
  "createdAt": "2026-06-29T00:00:00.000Z",
  "updatedAt": "2026-06-29T00:00:00.000Z",
  "name": "创建布局",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-layout-create-form",
      "type": "MForm",
      "data": {
        "values": {
          "uuid": {
            "mode": "flow",
            "flow": {
              "version": 1,
              "nodes": [
                {
                  "id": "empty_uuid",
                  "type": "constant",
                  "value": ""
                },
                {
                  "id": "generate_uuid",
                  "type": "processor",
                  "processors": [
                    {
                      "processor": "random_id",
                      "param": {
                        "prefix": "layout_",
                        "length": 6,
                        "when": "empty"
                      }
                    }
                  ]
                },
                {
                  "id": "output_uuid",
                  "type": "output"
                }
              ],
              "edges": [
                {
                  "id": "empty_uuid-generate_uuid",
                  "source": "empty_uuid",
                  "target": "generate_uuid"
                },
                {
                  "id": "generate_uuid-output_uuid",
                  "source": "generate_uuid",
                  "target": "output_uuid"
                }
              ],
              "layout": {
                "empty_uuid": {
                  "x": 80,
                  "y": 120
                },
                "generate_uuid": {
                  "x": 330,
                  "y": 120
                },
                "output_uuid": {
                  "x": 590,
                  "y": 120
                }
              },
              "outputNodeId": "output_uuid"
            }
          }
        },
        "items": [
          {
            "labelName": "布局 UUID",
            "variableName": "uuid",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "mokelay-layout-create-uuid-input",
              "type": "MInput",
              "data": {
                "placeholder": "请输入布局 UUID",
                "value": ""
              }
            },
            "events": []
          },
          {
            "labelName": "布局名称",
            "variableName": "name",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "mokelay-layout-create-name-input",
              "type": "MInput",
              "data": {
                "placeholder": "请输入布局名称",
                "value": "",
                "required": true
              }
            },
            "events": []
          }
        ]
      },
      "events": []
    },
    {
      "id": "mokelay-layout-create-save-button",
      "type": "MButton",
      "data": {
        "label": "保存布局",
        "variant": "primary",
        "align": "left",
        "action": {
          "type": "submit"
        }
      },
      "events": [
        {
          "event": "click",
          "actions": [
            {
              "uuid": "mokelay_layout_create_get_form_data",
              "action": "call_block_method",
              "alias": "获取布局表单数据",
              "inputs": {
                "blockId": "mokelay-layout-create-form",
                "method": "submit"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": "mokelay_layout_create_valid_route"
            },
            {
              "uuid": "mokelay_layout_create_valid_route",
              "action": "if_controller",
              "type": "controller",
              "alias": "校验布局表单",
              "inputs": {
                "value": {
                  "template": "{{actions['mokelay_layout_create_get_form_data'].outputs.returnData.valid}}"
                }
              },
              "nodes": [
                {
                  "uuid": "mokelay_layout_create_valid_true",
                  "alias": "校验通过",
                  "value": true,
                  "nextAction": "mokelay_layout_create_execute_ds"
                },
                {
                  "uuid": "mokelay_layout_create_valid_false",
                  "alias": "校验失败",
                  "value": false,
                  "nextAction": null
                }
              ]
            },
            {
              "uuid": "mokelay_layout_create_execute_ds",
              "action": "execute_ds",
              "alias": "创建布局",
              "inputs": {
                "dsConfig": {
                  "type": "API",
                  "domain": "mokelay",
                  "path": "/api/mokelay/create_layout",
                  "method": "POST",
                  "headerData": [],
                  "bodyData": [
                    {
                      "key": "uuid",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_layout_create_get_form_data'].outputs.returnData.values.uuid}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    },
                    {
                      "key": "name",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_layout_create_get_form_data'].outputs.returnData.values.name}}"
                      }
                    },
                    {
                      "key": "layoutJson",
                      "dataType": "object",
                      "value": {
                        "schemaVersion": 1,
                        "uuid": {
                          "template": "{{actions['mokelay_layout_create_get_form_data'].outputs.returnData.values.uuid}}"
                        },
                        "name": {
                          "template": "{{actions['mokelay_layout_create_get_form_data'].outputs.returnData.values.name}}"
                        },
                        "resources": {
                          "mainMenu": {
                            "type": "static",
                            "items": [
                              {
                                "label": "首页",
                                "href": "/"
                              }
                            ]
                          }
                        },
                        "auth": {
                          "enabled": false,
                          "endpoint": "/api/mokelay/me"
                        },
                        "blocks": [
                          {
                            "id": "page-content",
                            "type": "MPageSlot",
                            "data": {
                              "name": "default"
                            }
                          }
                        ]
                      }
                    }
                  ],
                  "queryData": [],
                  "schemaSelections": [
                    {
                      "path": "data.layout",
                      "type": "object",
                      "label": "创建布局"
                    }
                  ],
                  "matchingExternalFields": [
                    {
                      "label": "创建布局",
                      "variable": "createdLayout",
                      "matchFieldPath": "data.layout"
                    }
                  ]
                }
              },
              "outputs": [
                "rawResponse",
                "createdLayout"
              ],
              "nextAction": "mokelay_layout_create_close_page"
            },
            {
              "uuid": "mokelay_layout_create_close_page",
              "action": "call_block_method",
              "alias": "关闭创建布局弹窗",
              "inputs": {
                "blockId": "mokelay_layout_create_page",
                "method": "close"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": null
            }
          ]
        }
      ]
    }
  ]
}
