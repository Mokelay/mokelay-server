{
  "uuid": "block_component_docs",
  "name": "客户端 Block 文档管理",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "block-docs-title",
      "type": "MHeading",
      "data": {
        "text": "客户端 Block 文档管理",
        "level": "1",
        "align": "left"
      }
    },
    {
      "id": "block-docs-intro",
      "type": "MRichText",
      "data": {
        "content": "这里展示 docs_client_block 中由 @clientBlockDoc 注释同步而来的客户端 block 注册、工具箱、属性、默认值、保存规则、事件、方法和源码引用。页面编辑器的组件列表也会读取同一份后端 API 数据。"
      }
    },
    {
      "id": "block-docs-search-form",
      "type": "MForm",
      "data": {
        "layout": "Horizontal",
        "items": [
          {
            "labelName": "BlockType",
            "variableName": "blockType",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "block-docs-search-block-type",
              "type": "MInput",
              "data": {
                "placeholder": "请输入 BlockType",
                "value": ""
              }
            },
            "events": []
          },
          {
            "labelName": "启用",
            "variableName": "editorEnabled",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "block-docs-search-editor-enabled",
              "type": "MSelectField",
              "data": {
                "value": "",
                "options": [
                  {
                    "label": "全部",
                    "value": ""
                  },
                  {
                    "label": "是",
                    "value": "1"
                  },
                  {
                    "label": "否",
                    "value": "0"
                  }
                ]
              }
            },
            "events": []
          },
          {
            "labelName": "显示",
            "variableName": "toolboxVisible",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "block-docs-search-toolbox-visible",
              "type": "MSelectField",
              "data": {
                "value": "",
                "options": [
                  {
                    "label": "全部",
                    "value": ""
                  },
                  {
                    "label": "是",
                    "value": "1"
                  },
                  {
                    "label": "否",
                    "value": "0"
                  }
                ]
              }
            },
            "events": []
          },
          {
            "labelName": "分类",
            "variableName": "category",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "block-docs-search-category",
              "type": "MSelectField",
              "data": {
                "value": "",
                "options": [
                  {
                    "label": "全部",
                    "value": ""
                  },
                  {
                    "label": "动作",
                    "value": "action"
                  },
                  {
                    "label": "容器",
                    "value": "container"
                  },
                  {
                    "label": "内容",
                    "value": "content"
                  },
                  {
                    "label": "数据",
                    "value": "data"
                  },
                  {
                    "label": "表单",
                    "value": "form"
                  },
                  {
                    "label": "布局",
                    "value": "layout"
                  },
                  {
                    "label": "页面",
                    "value": "page"
                  }
                ]
              }
            },
            "events": []
          }
        ],
        "actionBar": {
          "align": "left",
          "size": "small",
          "mode": "inline",
          "buttons": [
            {
              "id": "search",
              "label": "查询",
              "variant": "secondary",
              "events": [
                {
                  "event": "click",
                  "actions": [
                    {
                      "uuid": "block_docs_search_get_form_data",
                      "action": "call_block_method",
                      "alias": "获取客户端 Block 查询条件",
                      "inputs": {
                        "blockId": "block-docs-search-form",
                        "method": "getData"
                      },
                      "outputs": [
                        "returnData"
                      ],
                      "nextAction": "block_docs_search_table"
                    },
                    {
                      "uuid": "block_docs_search_table",
                      "action": "call_block_method",
                      "alias": "查询客户端 Block 文档",
                      "inputs": {
                        "blockId": "block-docs-table",
                        "method": "search",
                        "args": {
                          "template": "{{actions['block_docs_search_get_form_data'].outputs.returnData}}"
                        }
                      },
                      "outputs": [
                        "returnData"
                      ],
                      "nextAction": null
                    }
                  ]
                }
              ]
            },
            {
              "id": "reset",
              "label": "重置",
              "variant": "ghost",
              "events": [
                {
                  "event": "click",
                  "actions": [
                    {
                      "uuid": "block_docs_reset_form",
                      "action": "call_block_method",
                      "alias": "重置客户端 Block 查询条件",
                      "inputs": {
                        "blockId": "block-docs-search-form",
                        "method": "reset"
                      },
                      "outputs": [
                        "returnData"
                      ],
                      "nextAction": "block_docs_reset_table"
                    },
                    {
                      "uuid": "block_docs_reset_table",
                      "action": "call_block_method",
                      "alias": "重置客户端 Block 文档列表",
                      "inputs": {
                        "blockId": "block-docs-table",
                        "method": "search",
                        "args": {
                          "template": "{{actions['block_docs_reset_form'].outputs.returnData.values}}"
                        }
                      },
                      "outputs": [
                        "returnData"
                      ],
                      "nextAction": null
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
      "events": []
    },
    {
      "id": "block-docs-table",
      "type": "MAdvanceTable",
      "data": {
        "index": true,
        "selection": false,
        "showPageBreak": true,
        "columns": [
          {
            "columnName": "Block Type",
            "fieldVariable": "block_type",
            "fieldDataType": "string",
            "width": 180,
            "fixed": "left",
            "columnContent": [
              {
                "id": "block-docs-col-type",
                "type": "paragraph",
                "data": {
                  "text": "{{block_type}}"
                }
              }
            ]
          },
          {
            "columnName": "名称",
            "fieldVariable": "display_name",
            "fieldDataType": "string",
            "width": 180,
            "fixed": null,
            "columnContent": [
              {
                "id": "block-docs-col-name",
                "type": "paragraph",
                "data": {
                  "text": "{{display_name}}"
                }
              }
            ]
          },
          {
            "columnName": "分类",
            "fieldVariable": "category",
            "fieldDataType": "string",
            "width": 150,
            "fixed": null,
            "columnContent": [
              {
                "id": "block-docs-col-category",
                "type": "paragraph",
                "data": {
                  "text": "{{category}} / {{source_kind}}"
                }
              }
            ]
          },
          {
            "columnName": "说明",
            "fieldVariable": "description",
            "fieldDataType": "string",
            "width": 420,
            "fixed": null,
            "columnContent": [
              {
                "id": "block-docs-col-description",
                "type": "paragraph",
                "data": {
                  "text": "{{description}}"
                }
              }
            ]
          },
          {
            "columnName": "工具箱",
            "fieldVariable": "toolbox_visible",
            "fieldDataType": "string",
            "width": 320,
            "fixed": null,
            "wrap": true,
            "columnContent": [
              {
                "id": "block-docs-editor-enabled-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "编辑器：已启用",
                  "variant": "text",
                  "align": "left",
                  "bare": true,
                  "visible": "{{editor_enabled}}"
                },
                "events": []
              },
              {
                "id": "block-docs-editor-disabled-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "编辑器：已停用",
                  "variant": "text",
                  "align": "left",
                  "bare": true,
                  "hidden": "{{editor_enabled}}"
                },
                "events": []
              },
              {
                "id": "block-docs-toolbox-shown-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "工具箱：显示",
                  "variant": "text",
                  "align": "left",
                  "bare": true,
                  "visible": "{{toolbox_visible}}"
                },
                "events": []
              },
              {
                "id": "block-docs-toolbox-hidden-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "工具箱：隐藏",
                  "variant": "text",
                  "align": "left",
                  "bare": true,
                  "hidden": "{{toolbox_visible}}"
                },
                "events": []
              },
              {
                "id": "block-docs-disable-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "停用",
                  "variant": "warning",
                  "align": "left",
                  "bare": true,
                  "visible": "{{editor_enabled}}"
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "block_docs_disable_request",
                        "action": "execute_ds",
                        "alias": "停用客户端 Block",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/update_client_block_doc_settings",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": "{{uuid}}"
                              },
                              {
                                "key": "editor_enabled",
                                "dataType": "boolean",
                                "value": false
                              },
                              {
                                "key": "toolbox_visible",
                                "dataType": "boolean",
                                "value": "{{toolbox_visible}}"
                              },
                              {
                                "key": "sort_order",
                                "dataType": "string",
                                "value": "{{sort_order}}"
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "block_docs_disable_refresh"
                      },
                      {
                        "uuid": "block_docs_disable_refresh",
                        "action": "call_block_method",
                        "alias": "刷新客户端 Block 文档",
                        "inputs": {
                          "blockId": "block-docs-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              },
              {
                "id": "block-docs-enable-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "启用",
                  "variant": "secondary",
                  "align": "left",
                  "bare": true,
                  "hidden": "{{editor_enabled}}"
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "block_docs_enable_request",
                        "action": "execute_ds",
                        "alias": "启用客户端 Block",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/update_client_block_doc_settings",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": "{{uuid}}"
                              },
                              {
                                "key": "editor_enabled",
                                "dataType": "boolean",
                                "value": true
                              },
                              {
                                "key": "toolbox_visible",
                                "dataType": "boolean",
                                "value": "{{toolbox_visible}}"
                              },
                              {
                                "key": "sort_order",
                                "dataType": "string",
                                "value": "{{sort_order}}"
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "block_docs_enable_refresh"
                      },
                      {
                        "uuid": "block_docs_enable_refresh",
                        "action": "call_block_method",
                        "alias": "刷新客户端 Block 文档",
                        "inputs": {
                          "blockId": "block-docs-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              },
              {
                "id": "block-docs-hide-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "隐藏",
                  "variant": "secondary",
                  "align": "left",
                  "bare": true,
                  "visible": "{{toolbox_visible}}"
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "block_docs_hide_request",
                        "action": "execute_ds",
                        "alias": "隐藏客户端 Block 工具箱项",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/update_client_block_doc_settings",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": "{{uuid}}"
                              },
                              {
                                "key": "editor_enabled",
                                "dataType": "boolean",
                                "value": "{{editor_enabled}}"
                              },
                              {
                                "key": "toolbox_visible",
                                "dataType": "boolean",
                                "value": false
                              },
                              {
                                "key": "sort_order",
                                "dataType": "string",
                                "value": "{{sort_order}}"
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "block_docs_hide_refresh"
                      },
                      {
                        "uuid": "block_docs_hide_refresh",
                        "action": "call_block_method",
                        "alias": "刷新客户端 Block 文档",
                        "inputs": {
                          "blockId": "block-docs-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              },
              {
                "id": "block-docs-show-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "展示",
                  "variant": "secondary",
                  "align": "left",
                  "bare": true,
                  "hidden": "{{toolbox_visible}}"
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "block_docs_show_request",
                        "action": "execute_ds",
                        "alias": "展示客户端 Block 工具箱项",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/update_client_block_doc_settings",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": "{{uuid}}"
                              },
                              {
                                "key": "editor_enabled",
                                "dataType": "boolean",
                                "value": "{{editor_enabled}}"
                              },
                              {
                                "key": "toolbox_visible",
                                "dataType": "boolean",
                                "value": true
                              },
                              {
                                "key": "sort_order",
                                "dataType": "string",
                                "value": "{{sort_order}}"
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "block_docs_show_refresh"
                      },
                      {
                        "uuid": "block_docs_show_refresh",
                        "action": "call_block_method",
                        "alias": "刷新客户端 Block 文档",
                        "inputs": {
                          "blockId": "block-docs-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              },
              {
                "id": "block-docs-sort-order-{{uuid}}",
                "type": "MInput",
                "data": {
                  "id": "block-docs-sort-order-{{uuid}}",
                  "value": "{{sort_order}}",
                  "placeholder": "排序",
                  "maxLength": 9
                },
                "events": []
              },
              {
                "id": "block-docs-save-sort-order-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "保存排序",
                  "variant": "secondary",
                  "align": "left",
                  "bare": true
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "block_docs_read_sort_order",
                        "action": "call_block_method",
                        "alias": "读取客户端 Block 排序",
                        "inputs": {
                          "blockId": "block-docs-sort-order-{{uuid}}",
                          "method": "getData"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": "block_docs_save_sort_order_request"
                      },
                      {
                        "uuid": "block_docs_save_sort_order_request",
                        "action": "execute_ds",
                        "alias": "保存客户端 Block 排序",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/update_client_block_doc_settings",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": "{{uuid}}"
                              },
                              {
                                "key": "editor_enabled",
                                "dataType": "boolean",
                                "value": "{{editor_enabled}}"
                              },
                              {
                                "key": "toolbox_visible",
                                "dataType": "boolean",
                                "value": "{{toolbox_visible}}"
                              },
                              {
                                "key": "sort_order",
                                "dataType": "string",
                                "value": {
                                  "template": "{{actions['block_docs_read_sort_order'].outputs.returnData.value}}"
                                }
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "block_docs_save_sort_order_refresh"
                      },
                      {
                        "uuid": "block_docs_save_sort_order_refresh",
                        "action": "call_block_method",
                        "alias": "刷新客户端 Block 文档",
                        "inputs": {
                          "blockId": "block-docs-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "columnName": "操作",
            "fieldVariable": "uuid",
            "fieldDataType": "string",
            "width": 112,
            "fixed": "right",
            "columnContent": [
              {
                "id": "block-docs-open-detail-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "查看详情",
                  "variant": "secondary",
                  "align": "left",
                  "bare": true
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "block_docs_open_detail",
                        "action": "jump_url",
                        "alias": "查看客户端 Block 文档详情",
                        "inputs": {
                          "url": {
                            "template": "/#/block_component_doc_detail?uuid={{uuid}}"
                          }
                        },
                        "outputs": [],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ],
        "ds": {
          "type": "API",
          "domain": "mokelay",
          "path": "/api/mokelay/list_client_block_docs",
          "method": "GET",
          "headerData": [],
          "bodyData": [],
          "queryData": [
            {
              "key": "page",
              "value": {
                "mode": "variable",
                "blockId": "block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "page"
              }
            },
            {
              "key": "pageSize",
              "value": {
                "mode": "variable",
                "blockId": "block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "pageSize"
              }
            },
            {
              "key": "blockType",
              "value": {
                "mode": "variable",
                "blockId": "block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "search.blockType"
              }
            },
            {
              "key": "status",
              "value": "active"
            },
            {
              "key": "editorEnabled",
              "value": {
                "mode": "variable",
                "blockId": "block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "search.editorEnabled"
              }
            },
            {
              "key": "toolboxVisible",
              "value": {
                "mode": "variable",
                "blockId": "block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "search.toolboxVisible"
              }
            },
            {
              "key": "category",
              "value": {
                "mode": "variable",
                "blockId": "block-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "search.category"
              }
            }
          ],
          "schemaSelections": [
            {
              "path": "data.docs[]",
              "label": "docs",
              "type": "array"
            },
            {
              "path": "data.pagination.page",
              "label": "page",
              "type": "number"
            },
            {
              "path": "data.pagination.pageSize",
              "label": "pageSize",
              "type": "number"
            },
            {
              "path": "data.pagination.total",
              "label": "total",
              "type": "number"
            }
          ],
          "matchingExternalFields": [
            {
              "label": "数据",
              "variable": "data",
              "type": "array",
              "matchFieldPath": "data.docs[]"
            },
            {
              "label": "页码",
              "variable": "page",
              "type": "number",
              "matchFieldPath": "data.pagination.page"
            },
            {
              "label": "每页数量",
              "variable": "pageSize",
              "type": "number",
              "matchFieldPath": "data.pagination.pageSize"
            },
            {
              "label": "总数",
              "variable": "total",
              "type": "number",
              "matchFieldPath": "data.pagination.total"
            }
          ]
        }
      }
    }
  ]
}
