{
  "uuid": "server_controller_docs",
  "name": "服务端 Controller 文档",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "server-controller-docs-title",
      "type": "MHeading",
      "data": {
        "text": "服务端 Controller 文档",
        "level": "1",
        "align": "left"
      }
    },
    {
      "id": "server-controller-docs-table",
      "type": "MAdvanceTable",
      "data": {
        "index": true,
        "selection": false,
        "showPageBreak": true,
        "columns": [
          {
            "columnName": "Function",
            "fieldVariable": "function_name",
            "fieldDataType": "string",
            "width": 190,
            "fixed": "left",
            "columnContent": [
              {
                "id": "server-controller-docs-col-function",
                "type": "paragraph",
                "data": {
                  "text": "{{function_name}}"
                }
              }
            ]
          },
          {
            "columnName": "名称",
            "fieldVariable": "display_name",
            "fieldDataType": "string",
            "width": 180,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-controller-docs-col-name",
                "type": "paragraph",
                "data": {
                  "text": "{{display_name}}"
                }
              }
            ]
          },
          {
            "columnName": "分类",
            "fieldVariable": "category",
            "fieldDataType": "string",
            "width": 170,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-controller-docs-col-category",
                "type": "paragraph",
                "data": {
                  "text": "{{category}} / {{source_kind}}"
                }
              }
            ]
          },
          {
            "columnName": "说明",
            "fieldVariable": "description",
            "fieldDataType": "string",
            "width": 420,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-controller-docs-col-description",
                "type": "paragraph",
                "data": {
                  "text": "{{description}}"
                }
              }
            ]
          },
          {
            "columnName": "源码",
            "fieldVariable": "source_file",
            "fieldDataType": "string",
            "width": 320,
            "fixed": null,
            "columnContent": [
              {
                "id": "server-controller-docs-col-source",
                "type": "paragraph",
                "data": {
                  "text": "{{source_file}}"
                }
              }
            ]
          },
          {
            "columnName": "操作",
            "fieldVariable": "uuid",
            "fieldDataType": "string",
            "width": 112,
            "fixed": "right",
            "columnContent": [
              {
                "id": "server-controller-docs-open-detail-{{uuid}}",
                "type": "MButton",
                "data": {
                  "label": "查看详情",
                  "variant": "secondary",
                  "align": "left",
                  "bare": true
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "server_controller_docs_open_detail",
                        "action": "jump_url",
                        "alias": "查看服务端 Controller 文档详情",
                        "inputs": {
                          "url": {
                            "template": "/#/server_controller_doc_detail?uuid={{uuid}}"
                          }
                        },
                        "outputs": [],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ],
        "ds": {
          "type": "API",
          "domain": "mokelay",
          "path": "/api/mokelay/list_server_controller_docs",
          "method": "GET",
          "headerData": [],
          "bodyData": [],
          "queryData": [
            {
              "key": "page",
              "value": {
                "mode": "variable",
                "blockId": "server-controller-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "page"
              }
            },
            {
              "key": "pageSize",
              "value": {
                "mode": "variable",
                "blockId": "server-controller-docs-table",
                "blockType": "MAdvanceTable",
                "variable": "pageSize"
              }
            }
          ],
          "schemaSelections": [
            {
              "path": "data.docs[]",
              "label": "docs",
              "type": "array"
            },
            {
              "path": "data.pagination.page",
              "label": "page",
              "type": "number"
            },
            {
              "path": "data.pagination.pageSize",
              "label": "pageSize",
              "type": "number"
            },
            {
              "path": "data.pagination.total",
              "label": "total",
              "type": "number"
            }
          ],
          "matchingExternalFields": [
            {
              "label": "数据",
              "variable": "data",
              "type": "array",
              "matchFieldPath": "data.docs[]"
            },
            {
              "label": "页码",
              "variable": "page",
              "type": "number",
              "matchFieldPath": "data.pagination.page"
            },
            {
              "label": "每页数量",
              "variable": "pageSize",
              "type": "number",
              "matchFieldPath": "data.pagination.pageSize"
            },
            {
              "label": "总数",
              "variable": "total",
              "type": "number",
              "matchFieldPath": "data.pagination.total"
            }
          ]
        }
      }
    }
  ]
}
