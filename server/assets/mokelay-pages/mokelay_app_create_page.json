{
  "uuid": "mokelay_app_create_page",
  "createdAt": "2026-07-03T00:00:00.000Z",
  "updatedAt": "2026-07-03T00:00:00.000Z",
  "name": "创建 App",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-app-create-form",
      "type": "MForm",
      "data": {
        "values": {
          "uuid": {
            "mode": "flow",
            "flow": {
              "version": 1,
              "nodes": [
                {
                  "id": "empty_uuid",
                  "type": "constant",
                  "value": ""
                },
                {
                  "id": "generate_uuid",
                  "type": "processor",
                  "processors": [
                    {
                      "processor": "random_id",
                      "param": {
                        "prefix": "app_",
                        "length": 4,
                        "when": "empty"
                      }
                    }
                  ]
                },
                {
                  "id": "output_uuid",
                  "type": "output"
                }
              ],
              "edges": [
                {
                  "id": "empty_uuid-generate_uuid",
                  "source": "empty_uuid",
                  "target": "generate_uuid"
                },
                {
                  "id": "generate_uuid-output_uuid",
                  "source": "generate_uuid",
                  "target": "output_uuid"
                }
              ],
              "layout": {
                "empty_uuid": {
                  "x": 80,
                  "y": 120
                },
                "generate_uuid": {
                  "x": 330,
                  "y": 120
                },
                "output_uuid": {
                  "x": 590,
                  "y": 120
                }
              },
              "outputNodeId": "output_uuid"
            }
          }
        },
        "items": [
          {
            "labelName": "App UUID",
            "variableName": "uuid",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "app-uuid",
              "type": "MInput",
              "data": {
                "placeholder": "最多 8 个字符，例如 mobile",
                "value": "",
                "required": true,
                "maxLength": 8
              }
            },
            "events": []
          },
          {
            "labelName": "名称",
            "variableName": "alias",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "create-app-alias",
              "type": "MInput",
              "data": {
                "placeholder": "请输入 App 名称",
                "value": "",
                "required": true,
                "maxLength": 120
              }
            },
            "events": []
          },
          {
            "labelName": "描述",
            "variableName": "description",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "create-app-description",
              "type": "MTextareaField",
              "data": {
                "placeholder": "请输入 App 描述",
                "value": "",
                "rows": 4
              }
            },
            "events": []
          }
        ]
      },
      "events": []
    },
    {
      "id": "create-app-submit",
      "type": "MButton",
      "data": {
        "label": "保存 App",
        "variant": "primary",
        "align": "right",
        "action": {
          "type": "submit"
        }
      },
      "events": [
        {
          "event": "click",
          "actions": [
            {
              "uuid": "mokelay_app_create_get_form_data",
              "action": "call_block_method",
              "alias": "获取 App 表单数据",
              "inputs": {
                "blockId": "mokelay-app-create-form",
                "method": "submit"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": "mokelay_app_create_valid_route"
            },
            {
              "uuid": "mokelay_app_create_valid_route",
              "action": "if_controller",
              "type": "controller",
              "alias": "校验 App 表单",
              "inputs": {
                "value": {
                  "template": "{{actions['mokelay_app_create_get_form_data'].outputs.returnData.valid}}"
                }
              },
              "nodes": [
                {
                  "uuid": "mokelay_app_create_valid_true",
                  "alias": "校验通过",
                  "value": true,
                  "nextAction": "mokelay_app_create_execute_ds"
                },
                {
                  "uuid": "mokelay_app_create_valid_false",
                  "alias": "校验失败",
                  "value": false,
                  "nextAction": null
                }
              ]
            },
            {
              "uuid": "mokelay_app_create_execute_ds",
              "action": "execute_ds",
              "alias": "创建 App",
              "inputs": {
                "dsConfig": {
                  "type": "API",
                  "domain": "mokelay",
                  "path": "/api/mokelay/create_app",
                  "method": "POST",
                  "headerData": [],
                  "bodyData": [
                    {
                      "key": "uuid",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_app_create_get_form_data'].outputs.returnData.values.uuid}}",
                        "processors": [
                          "trim",
                          {
                            "processor": "random_id",
                            "param": {
                              "prefix": "app_",
                              "length": 4,
                              "when": "empty"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "key": "alias",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_app_create_get_form_data'].outputs.returnData.values.alias}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    },
                    {
                      "key": "description",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_app_create_get_form_data'].outputs.returnData.values.description}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    }
                  ],
                  "queryData": [],
                  "schemaSelections": [
                    {
                      "path": "data.app",
                      "type": "object",
                      "label": "创建 App"
                    }
                  ],
                  "matchingExternalFields": [
                    {
                      "label": "创建 App",
                      "variable": "createdApp",
                      "matchFieldPath": "data.app"
                    }
                  ]
                }
              },
              "outputs": [
                "rawResponse",
                "createdApp"
              ],
              "nextAction": "mokelay_app_create_close_dialog"
            },
            {
              "uuid": "mokelay_app_create_close_dialog",
              "action": "close_dialog",
              "alias": "关闭创建 App 弹窗",
              "inputs": {
                "reason": "success",
                "result": {
                  "app": {
                    "template": "{{actions['mokelay_app_create_execute_ds'].outputs.createdApp}}"
                  }
                }
              },
              "outputs": [
                "closed",
                "reason",
                "result"
              ],
              "nextAction": null
            }
          ]
        }
      ]
    }
  ]
}
