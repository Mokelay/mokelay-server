{
  "uuid": "mokelay_create_page",
  "subPage": true,
  "quotes": ["mokelay_list_page"],
  "dependencies": [],
  "createdAt": "2026-06-23T00:00:00.000Z",
  "updatedAt": "2026-06-23T00:00:00.000Z",
  "name": "创建页面",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-create-page-form",
      "type": "MForm",
      "data": {
        "values": {
          "uuid": {
            "mode": "flow",
            "flow": {
              "version": 1,
              "nodes": [
                {
                  "id": "empty_uuid",
                  "type": "constant",
                  "value": ""
                },
                {
                  "id": "generate_uuid",
                  "type": "processor",
                  "processors": [
                    {
                      "processor": "random_id",
                      "param": {
                        "prefix": "page_",
                        "length": 6,
                        "when": "empty"
                      }
                    }
                  ]
                },
                {
                  "id": "output_uuid",
                  "type": "output"
                }
              ],
              "edges": [
                {
                  "id": "empty_uuid-generate_uuid",
                  "source": "empty_uuid",
                  "target": "generate_uuid"
                },
                {
                  "id": "generate_uuid-output_uuid",
                  "source": "generate_uuid",
                  "target": "output_uuid"
                }
              ],
              "layout": {
                "empty_uuid": {
                  "x": 80,
                  "y": 120
                },
                "generate_uuid": {
                  "x": 330,
                  "y": 120
                },
                "output_uuid": {
                  "x": 590,
                  "y": 120
                }
              },
              "outputNodeId": "output_uuid"
            }
          }
        },
        "items": [
          {
            "labelName": {
              "$i18n": {
                "zh-CN": "页面标识",
                "en-US": "Page Identifier"
              }
            },
            "variableName": "uuid",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "mokelay-create-page-uuid-input",
              "type": "MInput",
              "data": {
                "placeholder": {
                  "$i18n": {
                    "zh-CN": "小写字母、数字、下划线或连字符",
                    "en-US": "Lowercase letters, numbers, underscores, or hyphens"
                  }
                },
                "value": "",
                "maxLength": 128
              }
            },
            "events": []
          },
          {
            "labelName": {
              "$i18n": {
                "zh-CN": "页面名称",
                "en-US": "Page Name"
              }
            },
            "variableName": "name",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "mokelay-create-page-name-input",
              "type": "MInput",
              "data": {
                "placeholder": {
                  "$i18n": {
                    "zh-CN": "请输入页面名称",
                    "en-US": "Enter a page name"
                  }
                },
                "value": "",
                "required": true
              }
            },
            "events": []
          }
        ]
      },
      "events": []
    },
    {
      "id": "mokelay-create-page-save-button",
      "type": "MButton",
      "data": {
        "label": {
          "$i18n": {
            "zh-CN": "保存页面",
            "en-US": "Save Page"
          }
        },
        "variant": "primary",
        "align": "left",
        "action": {
          "type": "submit"
        }
      },
      "events": [
        {
          "event": "click",
          "actions": [
            {
              "uuid": "mokelay_create_page_get_form_data",
              "action": "call_block_method",
              "alias": "获取页面表单数据",
              "inputs": {
                "blockId": "mokelay-create-page-form",
                "method": "submit"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": "mokelay_create_page_valid_route"
            },
            {
              "uuid": "mokelay_create_page_valid_route",
              "action": "if_controller",
              "type": "controller",
              "alias": "校验页面表单",
              "inputs": {
                "value": {
                  "template": "{{actions['mokelay_create_page_get_form_data'].outputs.returnData.valid}}"
                }
              },
              "nodes": [
                {
                  "uuid": "mokelay_create_page_valid_true",
                  "alias": "校验通过",
                  "value": true,
                  "nextAction": "mokelay_create_page_confirm"
                },
                {
                  "uuid": "mokelay_create_page_valid_false",
                  "alias": "校验失败",
                  "value": false,
                  "nextAction": null
                }
              ]
            },
            {
              "uuid": "mokelay_create_page_confirm",
              "action": "confirm",
              "alias": "确认创建页面",
              "inputs": {
                "title": {
                  "$i18n": {
                    "zh-CN": "确认创建页面",
                    "en-US": "Confirm Page Creation"
                  }
                },
                "content": {
                  "$i18n": {
                    "zh-CN": "确定要创建该页面吗？",
                    "en-US": "Create this page?"
                  }
                }
              },
              "outputs": [
                "result"
              ],
              "nextAction": "mokelay_create_page_confirm_route"
            },
            {
              "uuid": "mokelay_create_page_confirm_route",
              "action": "if_controller",
              "type": "controller",
              "alias": "确认结果",
              "inputs": {
                "value": {
                  "template": "{{actions['mokelay_create_page_confirm'].outputs.result}}"
                }
              },
              "nodes": [
                {
                  "uuid": "mokelay_create_page_confirm_true",
                  "alias": "确认",
                  "value": true,
                  "nextAction": "mokelay_create_page_execute_ds"
                },
                {
                  "uuid": "mokelay_create_page_confirm_false",
                  "alias": "取消",
                  "value": false,
                  "nextAction": null
                }
              ]
            },
            {
              "uuid": "mokelay_create_page_execute_ds",
              "action": "execute_ds",
              "alias": "创建页面",
              "inputs": {
                "dsConfig": {
                  "type": "API",
                  "domain": "mokelay",
                  "path": "/api/mokelay/create_page",
                  "method": "POST",
                  "headerData": [],
                  "bodyData": [
                    {
                      "key": "uuid",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_create_page_get_form_data'].outputs.returnData.values.uuid}}",
                        "processors": [
                          "trim",
                          {
                            "processor": "random_id",
                            "param": {
                              "prefix": "page_",
                              "length": 6,
                              "when": "empty"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "key": "name",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_create_page_get_form_data'].outputs.returnData.values.name}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    },
                    {
                      "key": "blocks",
                      "dataType": "array",
                      "value": []
                    },
                    {
                      "key": "appUuid",
                      "dataType": "string",
                      "value": {
                        "mode": "variable",
                        "source": "MPage",
                        "variable": "context.appUuid"
                      }
                    }
                  ],
                  "queryData": [],
                  "schemaSelections": [
                    {
                      "path": "data.page",
                      "type": "object",
                      "label": "创建页面"
                    }
                  ],
                  "matchingExternalFields": [
                    {
                      "label": "创建页面",
                      "variable": "createdPage",
                      "matchFieldPath": "data.page"
                    }
                  ]
                }
              },
              "outputs": [
                "rawResponse",
                "createdPage"
              ],
              "nextAction": "mokelay_create_page_close_page"
            },
            {
              "uuid": "mokelay_create_page_close_page",
              "action": "call_block_method",
              "alias": "关闭创建页面",
              "inputs": {
                "blockId": "mokelay_create_page",
                "method": "close"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": null
            }
          ]
        }
      ]
    }
  ],
  "localeConfig": {
    "defaultLocale": "zh-CN",
    "supportedLocales": [
      "zh-CN",
      "en-US"
    ]
  }
}
