                            "label": {
                              "$i18n": {
                                "zh-CN": "删除",
                                "en-US": "Delete"
                              }
                            },
                            "variant": "danger",
                            "action": {
                              "uuid": "{{uuid}}",
                              "name": "{{name}}"
                            }
                          },
                          "events": [
                            {
                              "event": "click",
                              "actions": [
                                {
                                  "uuid": "mokelay_api_user_delete_confirm",
                                  "action": "confirm",
                                  "alias": "确认删除 API",
                                  "inputs": {
                                    "title": {
                                      "$i18n": {
                                        "zh-CN": "删除 API",
                                        "en-US": "Delete API"
                                      }
                                    },
                                    "content": {
                                      "template": "确认删除 {{sourceBlock.data.action.name}}？"
                                    },
                                    "confirmText": "删除",
                                    "cancelText": "取消"
                                  },
                                  "outputs": [
                                    "result"
                                  ],
                                  "nextAction": "mokelay_api_user_delete_if_confirmed"
