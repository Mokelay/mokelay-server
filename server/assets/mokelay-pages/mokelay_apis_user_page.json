                          "events": [
                            {
                              "event": "click",
                              "actions": [
                                {
                                  "uuid": "mokelay_api_user_open_detail",
                                  "action": "jump_url",
                                  "alias": "打开 API 详情",
                                  "inputs": {
                                    "url": {
                                      "template": "#/apis/{{sourceBlock.data.action.uuid}}?appUuid={{context.route.query.uuid}}"
