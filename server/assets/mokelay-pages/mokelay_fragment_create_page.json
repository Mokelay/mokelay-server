{
  "uuid": "mokelay_fragment_create_page",
  "subPage": true,
  "quotes": ["mokelay_apis_user_fragment_page"],
  "dependencies": [],
  "createdAt": "2026-07-15T00:00:00.000Z",
  "updatedAt": "2026-07-15T00:00:00.000Z",
  "name": "新建 Fragment",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-fragment-create-form",
      "type": "MForm",
      "data": {
        "values": {
          "name": {
            "mode": "variable",
            "source": "MPage",
            "variable": "context.name"
          },
          "uuid": {
            "mode": "flow",
            "flow": {
              "version": 1,
              "nodes": [
                {
                  "id": "context_uuid",
                  "type": "variable",
                  "source": "MPage",
                  "variable": "context.uuid"
                },
                {
                  "id": "generate_uuid",
                  "type": "processor",
                  "processors": [
                    {
                      "processor": "random_id",
                      "param": {
                        "prefix": "fragment_",
                        "length": 6,
                        "when": "empty"
                      }
                    }
                  ]
                },
                {
                  "id": "output_uuid",
                  "type": "output"
                }
              ],
              "edges": [
                {
                  "id": "context_uuid-generate_uuid",
                  "source": "context_uuid",
                  "target": "generate_uuid"
                },
                {
                  "id": "generate_uuid-output_uuid",
                  "source": "generate_uuid",
                  "target": "output_uuid"
                }
              ],
              "layout": {
                "context_uuid": {
                  "x": 80,
                  "y": 120
                },
                "generate_uuid": {
                  "x": 330,
                  "y": 120
                },
                "output_uuid": {
                  "x": 590,
                  "y": 120
                }
              },
              "outputNodeId": "output_uuid"
            }
          }
        },
        "submit": {
          "filterEmpty": false,
          "includeDisabled": true,
          "includeHidden": false
        },
        "items": [
          {
            "labelName": "Fragment 名称",
            "variableName": "name",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "fragment-create-name",
              "type": "MInput",
              "data": {
                "placeholder": "请输入 Fragment 名称",
                "value": "",
                "required": true,
                "validationMessage": "请输入 Fragment 名称"
              }
            },
            "events": []
          },
          {
            "labelName": "Fragment 标识",
            "variableName": "uuid",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "fragment-create-uuid",
              "type": "MInput",
              "data": {
                "placeholder": "例如 fragment_prepare_customer",
                "value": "",
                "required": true,
                "validationMessage": "请输入 Fragment 标识"
              }
            },
            "events": []
          }
        ]
      },
      "events": []
    },
    {
      "id": "mokelay-fragment-create-preview",
      "type": "paragraph",
      "data": {
        "text": "Fragment 标识：{{blocks[\"fragment-create-uuid\"].value}}"
      },
      "events": []
    },
    {
      "id": "mokelay-fragment-create-actions",
      "type": "MActionToolbar",
      "data": {
        "align": "right",
        "buttons": [
          {
            "id": "cancel",
            "label": "取消",
            "variant": "secondary",
            "events": [
              {
                "event": "click",
                "actions": [
                  {
                    "uuid": "mokelay_fragment_create_cancel",
                    "action": "close_dialog",
                    "alias": "取消新建 Fragment",
                    "inputs": {
                      "reason": "cancel"
                    },
                    "outputs": [
                      "closed",
                      "reason"
                    ],
                    "nextAction": null
                  }
                ]
              }
            ]
          },
          {
            "id": "save",
            "label": "保存并打开",
            "variant": "primary",
            "events": [
              {
                "event": "click",
                "actions": [
                  {
                    "uuid": "mokelay_fragment_create_read_form",
                    "action": "call_block_method",
                    "alias": "读取 Fragment 表单",
                    "inputs": {
                      "blockId": "mokelay-fragment-create-form",
                      "method": "getData"
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": "mokelay_fragment_create_normalize_uuid"
                  },
                  {
                    "uuid": "mokelay_fragment_create_normalize_uuid",
                    "action": "call_block_method",
                    "alias": "规范 Fragment 标识",
                    "inputs": {
                      "blockId": "mokelay-fragment-create-form",
                      "method": "setValues",
                      "args": {
                        "uuid": {
                          "template": "{{actions['mokelay_fragment_create_read_form'].outputs.returnData.uuid}}",
                          "processors": [
                            "trim",
                            {
                              "processor": "random_id",
                              "param": {
                                "prefix": "fragment_",
                                "length": 6,
                                "when": "empty"
                              }
                            }
                          ]
                        }
                      }
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": "mokelay_fragment_create_submit_form"
                  },
                  {
                    "uuid": "mokelay_fragment_create_submit_form",
                    "action": "call_block_method",
                    "alias": "提交 Fragment 表单",
                    "inputs": {
                      "blockId": "mokelay-fragment-create-form",
                      "method": "submit"
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": "mokelay_fragment_create_if_valid"
                  },
                  {
                    "uuid": "mokelay_fragment_create_if_valid",
                    "action": "if_controller",
                    "alias": "判断表单是否有效",
                    "inputs": {
                      "value": {
                        "template": "{{actions['mokelay_fragment_create_submit_form'].outputs.returnData.valid}}"
                      }
                    },
                    "nodes": [
                      {
                        "uuid": "true",
                        "value": true,
                        "nextAction": "mokelay_fragment_create_execute_save"
                      },
                      {
                        "uuid": "false",
                        "value": false,
                        "nextAction": null
                      }
                    ],
                    "nextAction": null
                  },
                  {
                    "uuid": "mokelay_fragment_create_execute_save",
                    "action": "execute_ds",
                    "alias": "保存 Fragment",
                    "inputs": {
                      "dsConfig": {
                        "type": "API",
                        "domain": "mokelay",
                        "path": "/api/mokelay/save_api",
                        "method": "POST",
                        "headerData": [],
                        "queryData": [],
                        "bodyData": [
                          {
                            "key": "uuid",
                            "dataType": "string",
                            "value": {
                              "template": "{{actions['mokelay_fragment_create_normalize_uuid'].outputs.returnData.values.uuid}}"
                            }
                          },
                          {
                            "key": "name",
                            "dataType": "string",
                            "value": {
                              "template": "{{actions['mokelay_fragment_create_submit_form'].outputs.returnData.values.name}}",
                              "processors": [
                                "trim"
                              ]
                            }
                          },
                          {
                            "key": "method",
                            "dataType": "string",
                            "value": "FRAGMENT"
                          },
                          {
                            "key": "fragment",
                            "dataType": "boolean",
                            "value": true
                          },
                          {
                            "key": "status",
                            "dataType": "string",
                            "value": "draft"
                          },
                          {
                            "key": "apiJson",
                            "dataType": "object",
                            "value": {
                              "uuid": {
                                "template": "{{actions['mokelay_fragment_create_normalize_uuid'].outputs.returnData.values.uuid}}"
                              },
                              "alias": {
                                "template": "{{actions['mokelay_fragment_create_submit_form'].outputs.returnData.values.name}}"
                              },
                              "fragment": true,
                              "params": [],
                              "blocks": [
                                {
                                  "uuid": "starter",
                                  "nextBlock": null
                                }
                              ],
                              "response": {}
                            }
                          },
                          {
                            "key": "layout",
                            "dataType": "object",
                            "value": {
                              "blocks": []
                            }
                          },
                          {
                            "key": "appUuid",
                            "dataType": "string",
                            "value": { "mode": "variable", "source": "MPage", "variable": "context.appUuid" }
                          }
                        ],
                        "schemaSelections": [
                          {
                            "path": "data.api",
                            "type": "object",
                            "label": "已保存 Fragment"
                          }
                        ],
                        "matchingExternalFields": [
                          {
                            "label": "已保存 Fragment",
                            "variable": "api",
                            "matchFieldPath": "data.api"
                          }
                        ]
                      }
                    },
                    "outputs": [
                      "rawResponse",
                      "api"
                    ],
                    "nextAction": "mokelay_fragment_create_close_dialog"
                  },
                  {
                    "uuid": "mokelay_fragment_create_close_dialog",
                    "action": "close_dialog",
                    "alias": "关闭新建 Fragment 弹窗",
                    "inputs": {
                      "reason": "success",
                      "result": {
                        "api": {
                          "template": "{{actions['mokelay_fragment_create_execute_save'].outputs.api}}"
                        }
                      }
                    },
                    "outputs": [
                      "closed",
                      "reason",
                      "result"
                    ],
                    "nextAction": "mokelay_fragment_create_open_created_api"
                  },
                  {
                    "uuid": "mokelay_fragment_create_open_created_api",
                    "action": "jump_url",
                    "alias": "打开新建 Fragment",
                    "inputs": {
                      "url": {
                        "template": "#/apis/{{actions['mokelay_fragment_create_execute_save'].outputs.api.uuid}}?fragment=true&appUuid={{context.appUuid}}"
                      }
                    },
                    "outputs": [],
                    "nextAction": null
                  }
                ]
              }
            ]
          }
        ]
      },
      "events": []
    }
  ]
}
