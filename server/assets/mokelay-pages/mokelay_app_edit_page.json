{
  "uuid": "mokelay_app_edit_page",
  "subPage": true,
  "quotes": ["home"],
  "dependencies": [],
  "createdAt": "2026-07-03T00:00:00.000Z",
  "updatedAt": "2026-07-03T00:00:00.000Z",
  "name": "编辑 App",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-app-edit-form",
      "type": "MForm",
      "data": {
        "values": {
          "uuid": {
            "mode": "variable",
            "source": "MPage",
            "variable": "context.uuid"
          },
          "alias": {
            "mode": "variable",
            "source": "MPage",
            "variable": "context.alias"
          },
          "description": {
            "mode": "variable",
            "source": "MPage",
            "variable": "context.description"
          }
        },
        "items": [
          {
            "labelName": "App UUID",
            "variableName": "uuid",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "app-uuid",
              "type": "MInput",
              "data": {
                "placeholder": "App UUID",
                "value": "",
                "disabled": true,
                "maxLength": 8
              }
            },
            "events": []
          },
          {
            "labelName": {
              "$i18n": {
                "zh-CN": "名称",
                "en-US": "Name"
              }
            },
            "variableName": "alias",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "create-app-alias",
              "type": "MInput",
              "data": {
                "placeholder": {
                  "$i18n": {
                    "zh-CN": "请输入 App 名称",
                    "en-US": "Enter an App name"
                  }
                },
                "value": "",
                "required": true,
                "maxLength": 120
              }
            },
            "events": []
          },
          {
            "labelName": {
              "$i18n": {
                "zh-CN": "描述",
                "en-US": "Description"
              }
            },
            "variableName": "description",
            "fieldDataType": "string",
            "layout": "Horizontal",
            "editor": {
              "id": "create-app-description",
              "type": "MTextareaField",
              "data": {
                "placeholder": {
                  "$i18n": {
                    "zh-CN": "请输入 App 描述",
                    "en-US": "Enter an App description"
                  }
                },
                "value": "",
                "rows": 4
              }
            },
            "events": []
          }
        ]
      },
      "events": []
    },
    {
      "id": "create-app-submit",
      "type": "MButton",
      "data": {
        "label": {
          "$i18n": {
            "zh-CN": "保存 App",
            "en-US": "Save App"
          }
        },
        "variant": "primary",
        "align": "right",
        "action": {
          "type": "submit"
        }
      },
      "events": [
        {
          "event": "click",
          "actions": [
            {
              "uuid": "mokelay_app_edit_get_form_data",
              "action": "call_block_method",
              "alias": "获取 App 表单数据",
              "inputs": {
                "blockId": "mokelay-app-edit-form",
                "method": "getData"
              },
              "outputs": [
                "returnData"
              ],
              "nextAction": "mokelay_app_edit_execute_ds"
            },
            {
              "uuid": "mokelay_app_edit_execute_ds",
              "action": "execute_ds",
              "alias": "更新 App",
              "inputs": {
                "dsConfig": {
                  "type": "API",
                  "domain": "mokelay",
                  "path": "/api/mokelay/update_app_by_uuid",
                  "method": "POST",
                  "headerData": [],
                  "bodyData": [
                    {
                      "key": "alias",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_app_edit_get_form_data'].outputs.returnData.alias}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    },
                    {
                      "key": "description",
                      "dataType": "string",
                      "value": {
                        "template": "{{actions['mokelay_app_edit_get_form_data'].outputs.returnData.description}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    }
                  ],
                  "queryData": [
                    {
                      "key": "uuid",
                      "value": {
                        "template": "{{actions['mokelay_app_edit_get_form_data'].outputs.returnData.uuid}}",
                        "processors": [
                          "trim"
                        ]
                      }
                    }
                  ],
                  "schemaSelections": [
                    {
                      "path": "data.app",
                      "type": "object",
                      "label": "更新 App"
                    }
                  ],
                  "matchingExternalFields": [
                    {
                      "label": "更新 App",
                      "variable": "updatedApp",
                      "matchFieldPath": "data.app"
                    }
                  ]
                }
              },
              "outputs": [
                "rawResponse",
                "updatedApp"
              ],
              "nextAction": "mokelay_app_edit_close_dialog"
            },
            {
              "uuid": "mokelay_app_edit_close_dialog",
              "action": "close_dialog",
              "alias": "关闭编辑 App 弹窗",
              "inputs": {
                "reason": "success",
                "result": {
                  "app": {
                    "template": "{{actions['mokelay_app_edit_execute_ds'].outputs.updatedApp}}"
                  }
                }
              },
              "outputs": [
                "closed",
                "reason",
                "result"
              ],
              "nextAction": null
            }
          ]
        }
      ]
    }
  ],
  "localeConfig": {
    "defaultLocale": "zh-CN",
    "supportedLocales": [
      "zh-CN",
      "en-US"
    ]
  }
}
