{
  "uuid": "mokelay_layouts_user_page",
  "createdAt": "2026-06-29T00:00:00.000Z",
  "updatedAt": "2026-06-29T00:00:00.000Z",
  "name": "用户创建布局",
  "layoutUuid": "mokelay_layout",
  "blocks": [
    {
      "id": "mokelay-layouts-user-heading",
      "type": "MHeading",
      "data": {
        "text": "用户创建布局",
        "level": 2,
        "align": "left"
      }
    },
    {
      "id": "mokelay-layouts-user-toolbar",
      "type": "MActionToolbar",
      "data": {
        "align": "right",
        "size": "small",
        "mode": "inline",
        "buttons": [
          {
            "id": "create",
            "label": "创建布局",
            "variant": "primary",
            "events": [
              {
                "event": "click",
                "actions": [
                  {
                    "uuid": "mokelay_layouts_user_open_create_dialog",
                    "action": "open_dialog",
                    "alias": "创建布局",
                    "inputs": {
                      "title": "创建布局",
                      "pageUUID": "mokelay_layout_create_page",
                      "pageSource": "system",
                      "context": {}
                    },
                    "outputs": [
                      "close_result"
                    ],
                    "nextAction": "mokelay_layouts_user_refresh_after_create"
                  },
                  {
                    "uuid": "mokelay_layouts_user_refresh_after_create",
                    "action": "call_block_method",
                    "alias": "刷新布局列表",
                    "inputs": {
                      "blockId": "mokelay-layouts-user-table",
                      "method": "refresh"
                    },
                    "outputs": [
                      "returnData"
                    ],
                    "nextAction": null
                  }
                ]
              }
            ]
          }
        ]
      },
      "events": []
    },
    {
      "id": "mokelay-layouts-user-table",
      "type": "MAdvanceTable",
      "data": {
        "index": false,
        "selection": false,
        "showPageBreak": true,
        "columns": [
          {
            "fixed": null,
            "width": 220,
            "columnName": "UUID",
            "columnContent": [
              {
                "id": "mokelay-layouts-user-uuid",
                "type": "paragraph",
                "data": {
                  "text": "{{uuid}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "uuid"
          },
          {
            "fixed": null,
            "width": null,
            "columnName": "名称",
            "columnContent": [
              {
                "id": "mokelay-layouts-user-name",
                "type": "paragraph",
                "data": {
                  "text": "{{name}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "name"
          },
          {
            "fixed": null,
            "width": 220,
            "columnName": "更新时间",
            "columnContent": [
              {
                "id": "mokelay-layouts-user-updated-at",
                "type": "paragraph",
                "data": {
                  "text": "{{updated_at}}"
                }
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "updated_at"
          },
          {
            "fixed": "right",
            "width": 180,
            "columnName": "操作",
            "columnContent": [
              {
                "id": "mokelay-layouts-user-open-button",
                "type": "MButton",
                "data": {
                  "label": "打开",
                  "variant": "secondary",
                  "align": "left",
                  "action": {
                    "type": "submit",
                    "uuid": "{{uuid}}",
                    "name": "{{name}}",
                    "layoutJson": "{{layout_json}}",
                    "createdAt": "{{created_at}}",
                    "updatedAt": "{{updated_at}}"
                  }
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "mokelay_layouts_user_open_editor_dialog",
                        "action": "open_dialog",
                        "alias": "编辑布局",
                        "inputs": {
                          "title": "编辑布局",
                          "pageUUID": "mokelay_layout_user_editor_page",
                          "pageSource": "system",
                          "context": {
                            "uuid": {
                              "template": "{{sourceBlock.data.action.uuid}}"
                            },
                            "name": {
                              "template": "{{sourceBlock.data.action.name}}"
                            },
                            "layoutJson": {
                              "template": "{{sourceBlock.data.action.layoutJson}}"
                            },
                            "createdAt": {
                              "template": "{{sourceBlock.data.action.createdAt}}"
                            },
                            "updatedAt": {
                              "template": "{{sourceBlock.data.action.updatedAt}}"
                            }
                          }
                        },
                        "outputs": [
                          "close_result"
                        ],
                        "nextAction": "mokelay_layouts_user_refresh_after_editor"
                      },
                      {
                        "uuid": "mokelay_layouts_user_refresh_after_editor",
                        "action": "call_block_method",
                        "alias": "刷新布局列表",
                        "inputs": {
                          "blockId": "mokelay-layouts-user-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              },
              {
                "id": "mokelay-layouts-user-delete-button",
                "type": "MButton",
                "data": {
                  "label": "删除",
                  "variant": "ghost",
                  "align": "left",
                  "action": {
                    "type": "submit",
                    "uuid": "{{uuid}}",
                    "name": "{{name}}"
                  }
                },
                "events": [
                  {
                    "event": "click",
                    "actions": [
                      {
                        "uuid": "mokelay_layouts_user_delete_confirm",
                        "action": "confirm",
                        "alias": "确认删除布局",
                        "inputs": {
                          "title": "确认删除布局",
                          "content": {
                            "template": "确定要删除布局「{{sourceBlock.data.action.name}}」吗？"
                          }
                        },
                        "outputs": [
                          "result"
                        ],
                        "nextAction": "mokelay_layouts_user_delete_confirm_route"
                      },
                      {
                        "uuid": "mokelay_layouts_user_delete_confirm_route",
                        "action": "if_controller",
                        "type": "controller",
                        "alias": "确认结果",
                        "inputs": {
                          "value": {
                            "template": "{{actions['mokelay_layouts_user_delete_confirm'].outputs.result}}"
                          }
                        },
                        "nodes": [
                          {
                            "uuid": "mokelay_layouts_user_delete_confirm_true",
                            "alias": "确认",
                            "value": true,
                            "nextAction": "mokelay_layouts_user_delete_execute_ds"
                          },
                          {
                            "uuid": "mokelay_layouts_user_delete_confirm_false",
                            "alias": "取消",
                            "value": false,
                            "nextAction": null
                          }
                        ]
                      },
                      {
                        "uuid": "mokelay_layouts_user_delete_execute_ds",
                        "action": "execute_ds",
                        "alias": "删除布局",
                        "inputs": {
                          "dsConfig": {
                            "type": "API",
                            "domain": "mokelay",
                            "path": "/api/mokelay/delete_layout_by_uuid",
                            "method": "POST",
                            "headerData": [],
                            "bodyData": [
                              {
                                "key": "uuid",
                                "dataType": "string",
                                "value": {
                                  "template": "{{sourceBlock.data.action.uuid}}"
                                }
                              }
                            ],
                            "queryData": []
                          }
                        },
                        "outputs": [
                          "rawResponse"
                        ],
                        "nextAction": "mokelay_layouts_user_delete_refresh_table"
                      },
                      {
                        "uuid": "mokelay_layouts_user_delete_refresh_table",
                        "action": "call_block_method",
                        "alias": "刷新布局列表",
                        "inputs": {
                          "blockId": "mokelay-layouts-user-table",
                          "method": "refresh"
                        },
                        "outputs": [
                          "returnData"
                        ],
                        "nextAction": null
                      }
                    ]
                  }
                ]
              }
            ],
            "fieldDataType": "string",
            "fieldVariable": "action"
          }
        ],
        "ds": {
          "type": "API",
          "domain": "mokelay",
          "path": "/api/mokelay/list_layouts",
          "method": "GET",
          "headerData": [],
          "bodyData": [],
          "queryData": [
            {
              "key": "page",
              "value": {
                "mode": "variable",
                "blockId": "mokelay-layouts-user-table",
                "blockType": "MAdvanceTable",
                "variable": "page"
              }
            },
            {
              "key": "pageSize",
              "value": {
                "mode": "variable",
                "blockId": "mokelay-layouts-user-table",
                "blockType": "MAdvanceTable",
                "variable": "pageSize"
              }
            }
          ],
          "schemaSelections": [
            {
              "path": "data.layouts[]",
              "type": "array",
              "label": "布局列表"
            },
            {
              "path": "data.pagination.page",
              "type": "number",
              "label": "当前页"
            },
            {
              "path": "data.pagination.pageSize",
              "type": "number",
              "label": "每页条数"
            },
            {
              "path": "data.pagination.total",
              "type": "number",
              "label": "总数"
            }
          ],
          "matchingExternalFields": [
            {
              "label": "列表数据",
              "variable": "data",
              "matchFieldPath": "data.layouts[]"
            },
            {
              "label": "当前页",
              "variable": "page",
              "matchFieldPath": "data.pagination.page"
            },
            {
              "label": "每页条数",
              "variable": "pageSize",
              "matchFieldPath": "data.pagination.pageSize"
            },
            {
              "label": "总数",
              "variable": "total",
              "matchFieldPath": "data.pagination.total"
            }
          ]
        }
      },
      "events": []
    }
  ]
}
