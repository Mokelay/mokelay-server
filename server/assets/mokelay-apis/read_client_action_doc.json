      "alias":"读取客户端 Action 文档 Block",
      "functionName":"read",
      "inputs":{
        "datasource":"Mokelay",
        "table":"docs_client_action",
        "fields":["id","uuid","action_name","display_name","action_type","category","source_kind","source_package","source_file","executor_name","description","status","input_schema","output_schema","error_schema","config_schema","node_schema","runtime_schema","examples","source_refs","raw_meta","created_at","updated_at"],
        "conditions":[{"group":false,"conditionType":"EQ","fieldName":"uuid","fieldValue":{"template":"{{request.query.uuid}}"}}]
      },
      "outputs":["data"],
      "nextBlock":null
    }
  ],
  "responses":{"read_client_action_doc_block":{"doc":{"template":"{{blocks['read_client_action_doc_block'].outputs.data}}"}}}
}
