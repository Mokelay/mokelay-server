{
  "uuid": "batch_delete_pages",
  "alias": "批量删除页面接口",
  "method": "POST",
  "request": {
    "body": [
      {
        "key": "uuids",
        "processors": ["is_not_null", "string_array_check", { "processor": "min", "param": [1] }]
      }
    ]
  },
  "blocks": [
    { "uuid": "starter", "nextBlock": "delete_page_relations_block" },
    {
      "uuid": "delete_page_relations_block",
      "alias": "事务批量删除页面并维护引用图",
      "functionName": "deletePageRelations",
      "inputs": {
        "datasource": "Mokelay",
        "uuids": { "template": "{{request.body.uuids}}" }
      },
      "outputs": ["affected"],
      "nextBlock": null
    }
  ],
  "responses": {
    "delete_page_relations_block": {
      "affected": { "template": "{{blocks['delete_page_relations_block'].outputs.affected}}" },
      "message": "批量删除成功"
    }
  }
}
