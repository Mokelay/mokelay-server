{
  "uuid": "create_user_info",
  "alias": "添加用户信息接口",
  "method": "POST",
  "request": {
    "body": ["name", "email", "password_hash"]
  },
  "blocks": [
    {
      "uuid": "ax2e",
      "alias": "添加Block",
      "functionName": "create",
      "inputs": {
        "table": "users",
        "fields": {
          "name": {
            "template": "{{request.body.name}}"
          },
          "email": {
            "template": "{{request.body.email}}"
          },
          "password_hash": {
            "template": "{{request.body.password_hash}}"
          }
        }
      },
      "outputs": ["id"]
    }
  ],
  "response": {
    "id": {
      "template": "{{blocks['ax2e'].outputs.id}}"
    }
  }
}
