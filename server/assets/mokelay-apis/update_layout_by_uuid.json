{
  "uuid": "update_layout_by_uuid",
  "alias": "更新布局接口",
  "method": "POST",
  "request": {
    "query": [
      "uuid"
    ],
    "body": [
      {
        "key": "name",
        "processors": [
          "trim",
          "is_not_null",
          {
            "processor": "max",
            "param": [
              120
            ]
          }
        ]
      },
      "layoutJson"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "update_layout_block"
    },
    {
      "uuid": "update_layout_block",
      "alias": "更新布局 Block",
      "functionName": "update",
      "inputs": {
        "datasource": "Mokelay",
        "table": "layouts",
        "fields": {
          "name": {
            "template": "{{request.body.name}}"
          },
          "layout_json": {
            "template": "{{request.body.layoutJson}}"
          },
          "updated_at": {
            "template": "{{now}}"
          }
        },
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "affected"
      ],
      "nextBlock": "read_layout_block"
    },
    {
      "uuid": "read_layout_block",
      "alias": "读取布局 Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "layouts",
        "fields": [
          "uuid",
          "name",
          "layout_json",
          "created_at",
          "updated_at"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_layout_block": {
      "affected": {
        "template": "{{blocks['update_layout_block'].outputs.affected}}"
      },
      "layout": {
        "uuid": {
          "template": "{{blocks['read_layout_block'].outputs.data.uuid}}"
        },
        "name": {
          "template": "{{blocks['read_layout_block'].outputs.data.name}}"
        },
        "layoutJson": {
          "template": "{{blocks['read_layout_block'].outputs.data.layout_json}}"
        },
        "createdAt": {
          "template": "{{blocks['read_layout_block'].outputs.data.created_at}}"
        },
        "updatedAt": {
          "template": "{{blocks['read_layout_block'].outputs.data.updated_at}}"
        }
      }
    }
  }
}
