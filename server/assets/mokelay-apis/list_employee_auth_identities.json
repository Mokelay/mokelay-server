{
  "uuid": "list_employee_auth_identities",
  "alias": "员工授权列表接口",
  "method": "GET",
  "request": {
    "query": [
      "page",
      "pageSize"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "list_employee_auth_identities_block"
    },
    {
      "uuid": "list_employee_auth_identities_block",
      "alias": "员工授权分页 Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employee_auth_identities",
        "fields": [
          "id",
          "employee_id",
          "provider",
          "provider_user_id",
          "provider_email",
          "email_verified",
          "created_at",
          "updated_at"
        ],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "orderBy": [
          {
            "fieldName": "updated_at",
            "direction": "DESC"
          },
          {
            "fieldName": "created_at",
            "direction": "DESC"
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "list_employee_auth_identities_block": {
      "employee_auth_identities": {
        "template": "{{blocks['list_employee_auth_identities_block'].outputs.datas}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['list_employee_auth_identities_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['list_employee_auth_identities_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['list_employee_auth_identities_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['list_employee_auth_identities_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['list_employee_auth_identities_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['list_employee_auth_identities_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
