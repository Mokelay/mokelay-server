{
  "uuid": "delete_api_by_uuid",
  "alias": "删除 API 接口",
  "method": "POST",
  "request": {
    "body": [
      "uuid"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "functionName": "requireTenantContext",
      "inputs": { "datasource": "Mokelay" },
      "outputs": ["enterpriseUuid"],
      "nextBlock": "assert_api_deletable_block"
    },
    {
      "uuid": "assert_api_deletable_block",
      "alias": "校验 API/Fragment 可删除",
      "functionName": "assertApiDefinitionsDeletable",
      "inputs": {
        "datasource": "Mokelay",
        "uuids": [
          {
            "template": "{{request.body.uuid}}"
          }
        ]
      },
      "outputs": [],
      "nextBlock": "delete_api_block"
    },
    {
      "uuid": "delete_api_block",
      "alias": "删除 API Block",
      "functionName": "delete",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis",
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.body.uuid}}"
            }
          },
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "enterprise_uuid",
            "fieldValue": { "template": "{{blocks['require_tenant_context'].outputs.enterpriseUuid}}" }
          }
        ]
      },
      "outputs": [
        "affected"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "delete_api_block": {
      "affected": {
        "template": "{{blocks['delete_api_block'].outputs.affected}}"
      },
      "message": "删除成功"
    }
  }
}
