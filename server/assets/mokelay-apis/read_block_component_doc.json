{
  "uuid": "read_block_component_doc",
  "alias": "读取 Block 组件文档接口",
  "method": "GET",
  "request": {
    "query": [
      "uuid"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "read_block_doc_block"
    },
    {
      "uuid": "read_block_doc_block",
      "alias": "读取 Block 文档 Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "docs_client_block",
        "fields": [
          "id",
          "uuid",
          "block_type",
          "display_name",
          "category",
          "source_kind",
          "source_package",
          "source_file",
          "component_name",
          "tool_symbol",
          "description",
          "status",
          "editor_enabled",
          "toolbox_visible",
          "sort_order",
          "registration",
          "toolbox",
          "initial_props",
          "default_data",
          "property_schema",
          "event_schema",
          "method_schema",
          "data_fields_schema",
          "save_schema",
          "examples",
          "source_refs",
          "raw_meta",
          "created_at",
          "updated_at"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_block_doc_block": {
      "doc": {
        "template": "{{blocks['read_block_doc_block'].outputs.data}}"
      }
    }
  }
}
