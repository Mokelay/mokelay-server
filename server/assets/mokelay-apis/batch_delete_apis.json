{
  "uuid": "batch_delete_apis",
  "alias": "批量删除 API 接口",
  "method": "POST",
  "request": {
    "body": [
      {
        "key": "uuids",
        "processors": [
          "is_not_null",
          "string_array_check",
          {
            "processor": "min",
            "param": [
              1
            ]
          }
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "batch_delete_apis_block"
    },
    {
      "uuid": "batch_delete_apis_block",
      "alias": "批量删除 API Block",
      "functionName": "delete",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis",
        "conditions": [
          {
            "group": false,
            "conditionType": "IN",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.body.uuids}}"
            }
          }
        ]
      },
      "outputs": [
        "affected"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "batch_delete_apis_block": {
      "affected": {
        "template": "{{blocks['batch_delete_apis_block'].outputs.affected}}"
      },
      "message": "批量删除成功"
    }
  }
}
