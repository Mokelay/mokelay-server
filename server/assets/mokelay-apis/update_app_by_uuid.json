{
  "uuid": "update_app_by_uuid",
  "alias": "修改 App 接口",
  "method": "POST",
  "request": {
    "query": [
      "uuid"
    ],
    "body": [
      {
        "key": "alias",
        "processors": [
          "trim",
          "is_not_null",
          {
            "processor": "max",
            "param": [
              120
            ]
          }
        ]
      },
      {
        "key": "description",
        "processors": [
          "trim",
          {
            "processor": "default_value",
            "param": ""
          }
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "functionName": "requireTenantContext",
      "inputs": {
        "datasource": "Mokelay",
        "appUuid": { "template": "{{request.query.uuid}}" },
        "requireApp": true
      },
      "outputs": ["enterpriseUuid", "appUuid"],
      "nextBlock": "update_app_block"
    },
    {
      "uuid": "update_app_block",
      "alias": "修改 App Block",
      "functionName": "update",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apps",
        "fields": {
          "alias": {
            "template": "{{request.body.alias}}"
          },
          "description": {
            "template": "{{request.body.description}}"
          }
        },
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "affected"
      ],
      "nextBlock": "read_app_block"
    },
    {
      "uuid": "read_app_block",
      "alias": "读取修改后的 App Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apps",
        "fields": [
          "id",
          "uuid",
          "alias",
          "description"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_app_block": {
      "affected": {
        "template": "{{blocks['update_app_block'].outputs.affected}}"
      },
      "app": {
        "id": {
          "template": "{{blocks['read_app_block'].outputs.data.id}}"
        },
        "uuid": {
          "template": "{{blocks['read_app_block'].outputs.data.uuid}}"
        },
        "alias": {
          "template": "{{blocks['read_app_block'].outputs.data.alias}}"
        },
        "description": {
          "template": "{{blocks['read_app_block'].outputs.data.description}}"
        }
      }
    }
  }
}
