{
  "uuid": "list_bingx_wallets",
  "alias": "BingX 钱包列表接口",
  "method": "GET",
  "blocks": [
    {
      "uuid": "list_wallets_block",
      "alias": "钱包列表Block",
      "functionName": "list",
      "inputs": {
        "datasource": "BingX",
        "table": "wallets",
        "fields": ["id", "chain_id", "address", "label", "wallet_type", "first_seen_at", "last_seen_at", "created_at", "updated_at"],
        "orderBy": [
          {
            "fieldName": "updated_at",
            "direction": "DESC"
          },
          {
            "fieldName": "created_at",
            "direction": "DESC"
          }
        ]
      },
      "outputs": ["datas"]
    }
  ],
  "response": {
    "wallets": {
      "template": "{{blocks['list_wallets_block'].outputs.datas}}"
    }
  }
}
