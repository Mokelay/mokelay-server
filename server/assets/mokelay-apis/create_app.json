{
  "uuid": "create_app",
  "alias": "创建 App 接口",
  "method": "POST",
  "request": {
    "body": [
      {
        "key": "uuid",
        "processors": [
          "trim",
          "is_not_null",
          {
            "processor": "max",
            "param": [
              8
            ]
          }
        ]
      },
      {
        "key": "alias",
        "processors": [
          "trim",
          "is_not_null",
          {
            "processor": "max",
            "param": [
              120
            ]
          }
        ]
      },
      {
        "key": "description",
        "processors": [
          "trim",
          {
            "processor": "default_value",
            "param": ""
          }
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "alias": "读取当前企业",
      "functionName": "requireTenantContext",
      "inputs": { "datasource": "Mokelay" },
      "outputs": ["enterpriseUuid"],
      "nextBlock": "create_app_block"
    },
    {
      "uuid": "create_app_block",
      "alias": "创建 App Block",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apps",
        "idField": "id",
        "fields": {
          "uuid": {
            "template": "{{request.body.uuid}}"
          },
          "alias": {
            "template": "{{request.body.alias}}"
          },
          "description": {
            "template": "{{request.body.description}}"
          },
          "enterprise_uuid": {
            "template": "{{blocks['require_tenant_context'].outputs.enterpriseUuid}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "read_app_block"
    },
    {
      "uuid": "read_app_block",
      "alias": "读取 App Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apps",
        "fields": [
          "id",
          "uuid",
          "alias",
          "description"
          ,"enterprise_uuid"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "id",
            "fieldValue": {
              "template": "{{blocks['create_app_block'].outputs.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_app_block": {
      "app": {
        "id": {
          "template": "{{blocks['read_app_block'].outputs.data.id}}"
        },
        "uuid": {
          "template": "{{blocks['read_app_block'].outputs.data.uuid}}"
        },
        "alias": {
          "template": "{{blocks['read_app_block'].outputs.data.alias}}"
        },
        "description": {
          "template": "{{blocks['read_app_block'].outputs.data.description}}"
        },
        "enterpriseUuid": {
          "template": "{{blocks['read_app_block'].outputs.data.enterprise_uuid}}"
        }
      }
    }
  }
}
