{
  "uuid": "list_apis",
  "alias": "API 列表接口",
  "method": "GET",
  "request": {
    "query": [
      "page",
      "pageSize",
      {
        "key": "fragment",
        "processors": [
          "boolean_value"
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "list_apis_block"
    },
    {
      "uuid": "list_apis_block",
      "alias": "API 分页 Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis",
        "fields": [
          "uuid",
          "name",
          "method",
          "fragment",
          "status",
          "created_at",
          "updated_at"
        ],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "conditions": [
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "fragment",
            "fieldValue": {
              "template": "{{request.query.fragment}}"
            }
          }
        ],
        "orderBy": [
          {
            "fieldName": "updated_at",
            "direction": "DESC"
          },
          {
            "fieldName": "created_at",
            "direction": "DESC"
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "list_apis_block": {
      "apis": {
        "template": "{{blocks['list_apis_block'].outputs.datas}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['list_apis_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['list_apis_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['list_apis_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['list_apis_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['list_apis_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['list_apis_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
