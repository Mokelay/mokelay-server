{
  "uuid": "create_page",
  "alias": "创建页面接口",
  "method": "POST",
  "request": {
    "body": [
      "name",
      "blocks",
      { "key": "uuid" },
      { "key": "subPage" },
      { "key": "quotes" },
      { "key": "dependencies" },
      { "key": "localeConfig" },
      { "key": "appUuid", "processors": ["trim", "is_not_null"] }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "functionName": "requireTenantContext",
      "inputs": {
        "datasource": "Mokelay",
        "appUuid": { "template": "{{request.body.appUuid}}" },
        "requireApp": true
      },
      "outputs": ["enterpriseUuid", "appUuid"],
      "nextBlock": "save_page_relations_block"
    },
    {
      "uuid": "save_page_relations_block",
      "alias": "事务创建页面并维护引用图",
      "functionName": "savePageRelations",
      "inputs": {
        "datasource": "Mokelay",
        "mode": "create",
        "uuid": { "template": "{{request.body.uuid}}" },
        "name": { "template": "{{request.body.name}}" },
        "blocks": { "template": "{{request.body.blocks}}" },
        "subPage": { "template": "{{request.body.subPage}}" },
        "quotes": { "template": "{{request.body.quotes}}" },
        "dependencies": { "template": "{{request.body.dependencies}}" },
        "localeConfig": { "template": "{{request.body.localeConfig}}" },
        "enterpriseUuid": { "template": "{{blocks['require_tenant_context'].outputs.enterpriseUuid}}" },
        "appUuid": { "template": "{{blocks['require_tenant_context'].outputs.appUuid}}" }
      },
      "outputs": ["affected", "page"],
      "nextBlock": null
    }
  ],
  "responses": {
    "save_page_relations_block": {
      "page": { "template": "{{blocks['save_page_relations_block'].outputs.page}}" }
    }
  }
}
