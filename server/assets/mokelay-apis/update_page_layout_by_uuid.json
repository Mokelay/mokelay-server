{
  "uuid": "update_page_layout_by_uuid",
  "alias": "更新页面布局绑定接口",
  "method": "POST",
  "request": {
    "query": [
      "uuid"
    ],
    "body": [
      {
        "key": "appUuid",
        "processors": [
          "trim",
          {
            "processor": "default_value",
            "param": null
          }
        ]
      },
      {
        "key": "layoutUuid",
        "processors": [
          "trim",
          {
            "processor": "default_value",
            "param": null
          }
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "update_page_layout_block"
    },
    {
      "uuid": "update_page_layout_block",
      "alias": "更新页面布局绑定 Block",
      "functionName": "update",
      "inputs": {
        "datasource": "Mokelay",
        "table": "pages",
        "fields": {
          "app_uuid": {
            "template": "{{request.body.appUuid}}"
          },
          "layout_uuid": {
            "template": "{{request.body.layoutUuid}}"
          },
          "updated_at": {
            "template": "{{now}}"
          }
        },
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "affected"
      ],
      "nextBlock": "read_page_block"
    },
    {
      "uuid": "read_page_block",
      "alias": "读取页面 Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "pages",
        "fields": [
          "uuid",
          "name",
          "blocks",
          "app_uuid",
          "layout_uuid",
          "created_at",
          "updated_at"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_page_block": {
      "affected": {
        "template": "{{blocks['update_page_layout_block'].outputs.affected}}"
      },
      "page": {
        "uuid": {
          "template": "{{blocks['read_page_block'].outputs.data.uuid}}"
        },
        "name": {
          "template": "{{blocks['read_page_block'].outputs.data.name}}"
        },
        "blocks": {
          "template": "{{blocks['read_page_block'].outputs.data.blocks}}"
        },
        "appUuid": {
          "template": "{{blocks['read_page_block'].outputs.data.app_uuid}}"
        },
        "layoutUuid": {
          "template": "{{blocks['read_page_block'].outputs.data.layout_uuid}}"
        },
        "createdAt": {
          "template": "{{blocks['read_page_block'].outputs.data.created_at}}"
        },
        "updatedAt": {
          "template": "{{blocks['read_page_block'].outputs.data.updated_at}}"
        }
      }
    }
  }
}
