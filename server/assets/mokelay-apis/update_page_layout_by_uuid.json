{
  "uuid": "update_page_layout_by_uuid",
  "alias": "更新页面布局绑定接口",
  "method": "POST",
  "request": {
    "query": ["uuid"],
    "body": [
      { "key": "appUuid", "processors": ["trim", { "processor": "default_value", "param": null }] },
      { "key": "layoutUuid", "processors": ["trim", { "processor": "default_value", "param": null }] }
    ]
  },
  "blocks": [
    { "uuid": "starter", "nextBlock": "normalize_page_uuid_block" },
    {
      "uuid": "normalize_page_uuid_block",
      "alias": "规范化页面标识",
      "functionName": "normalizePageUuid",
      "inputs": { "uuid": { "template": "{{request.query.uuid}}" } },
      "outputs": ["uuid"],
      "nextBlock": "update_page_layout_block"
    },
    {
      "uuid": "update_page_layout_block",
      "alias": "更新页面布局绑定 Block",
      "functionName": "update",
      "inputs": {
        "datasource": "Mokelay",
        "table": "pages",
        "fields": {
          "app_uuid": { "template": "{{request.body.appUuid}}" },
          "layout_uuid": { "template": "{{request.body.layoutUuid}}" },
          "updated_at": { "template": "{{now}}" }
        },
        "conditions": [{
          "group": false,
          "conditionType": "EQ",
          "fieldName": "uuid",
          "fieldValue": { "template": "{{blocks['normalize_page_uuid_block'].outputs.uuid}}" }
        }]
      },
      "outputs": ["affected"],
      "nextBlock": "read_page_block"
    },
    {
      "uuid": "read_page_block",
      "alias": "读取页面 Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "pages",
        "fields": [
          "uuid", "name", "blocks", "app_uuid", "layout_uuid",
          "sub_page", "quotes", "dependencies", "created_at", "updated_at"
        ],
        "conditions": [{
          "group": false,
          "conditionType": "EQ",
          "fieldName": "uuid",
          "fieldValue": { "template": "{{blocks['normalize_page_uuid_block'].outputs.uuid}}" }
        }]
      },
      "outputs": ["data"],
      "nextBlock": "normalize_page_row_block"
    },
    {
      "uuid": "normalize_page_row_block",
      "alias": "标准化页面关系字段",
      "functionName": "normalizePageRows",
      "inputs": {
        "row": { "template": "{{blocks['read_page_block'].outputs.data}}" },
        "affected": { "template": "{{blocks['update_page_layout_block'].outputs.affected}}" }
      },
      "outputs": ["page", "affected"],
      "nextBlock": null
    }
  ],
  "responses": {
    "normalize_page_row_block": {
      "affected": { "template": "{{blocks['normalize_page_row_block'].outputs.affected}}" },
      "page": { "template": "{{blocks['normalize_page_row_block'].outputs.page}}" }
    }
  }
}
