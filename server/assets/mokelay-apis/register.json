{
  "uuid": "register",
  "alias": "注册接口",
  "method": "POST",
  "request": {
    "body": [
      {
        "key": "enterprise_name",
        "processors": [
          "trim",
          "is_not_null",
          {
            "processor": "max",
            "param": [
              120
            ]
          }
        ]
      },
      {
        "key": "name",
        "processors": [
          "trim",
          {
            "processor": "min",
            "param": [
              1
            ]
          },
          {
            "processor": "max",
            "param": [
              120
            ]
          }
        ]
      },
      {
        "key": "email",
        "processors": [
          "trim",
          "is_not_null",
          "email_check",
          {
            "processor": "max",
            "param": [
              255
            ]
          }
        ]
      },
      {
        "key": "password",
        "processors": [
          "is_not_null",
          {
            "processor": "min",
            "param": [
              8
            ]
          },
          {
            "processor": "max",
            "param": [
              128
            ]
          },
          {
            "processor": "regex",
            "param": "/[A-Za-z]/"
          },
          {
            "processor": "regex",
            "param": "/[0-9]/"
          },
          "hash_make"
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "check_email_duplicate"
    },
    {
      "uuid": "check_email_duplicate",
      "alias": "检查Email是否有重复注册",
      "functionName": "count",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "email",
            "fieldValue": {
              "template": "{{request.body.email}}"
            }
          }
        ]
      },
      "outputs": [
        {
          "key": "total",
          "processors": [
            {
              "processor": "eq",
              "param": [
                0
              ]
            }
          ]
        }
      ],
      "nextBlock": "create_enterprise_info"
    },
    {
      "uuid": "create_enterprise_info",
      "alias": "创建企业信息",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "enterprise",
        "idField": "uuid",
        "fields": {
          "name": {
            "template": "{{request.body.enterprise_name}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "read_enterprise_info"
    },
    {
      "uuid": "read_enterprise_info",
      "alias": "读取创建的企业信息",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "enterprise",
        "fields": [
          "uuid",
          "name"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{blocks['create_enterprise_info'].outputs.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": "create_employee_info"
    },
    {
      "uuid": "create_employee_info",
      "alias": "创建员工信息",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "idField": "id",
        "fields": {
          "enterprise_uuid": {
            "template": "{{blocks['create_enterprise_info'].outputs.uuid}}"
          },
          "name": {
            "template": "{{request.body.name}}"
          },
          "email": {
            "template": "{{request.body.email}}"
          },
          "password_hash": {
            "template": "{{request.body.password}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "read_employee_info"
    },
    {
      "uuid": "read_employee_info",
      "alias": "读取创建的员工信息",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "fields": [
          "id",
          "enterprise_uuid",
          "name",
          "email",
          "plan"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "id",
            "fieldValue": {
              "template": "{{blocks['create_employee_info'].outputs.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": "set_user_session"
    },
    {
      "uuid": "set_user_session",
      "alias": "保存员工信息到Session",
      "functionName": "addSession",
      "inputs": {
        "key": "user",
        "value": {
          "id": {
            "template": "{{blocks['read_employee_info'].outputs.data.id}}"
          },
          "enterprise_uuid": {
            "template": "{{blocks['read_employee_info'].outputs.data.enterprise_uuid}}"
          },
          "enterprise_name": {
            "template": "{{blocks['read_enterprise_info'].outputs.data.name}}"
          },
          "name": {
            "template": "{{blocks['read_employee_info'].outputs.data.name}}"
          },
          "email": {
            "template": "{{blocks['read_employee_info'].outputs.data.email}}"
          },
          "plan": {
            "template": "{{blocks['read_employee_info'].outputs.data.plan}}"
          }
        }
      },
      "nextBlock": null
    }
  ],
  "responses": {
    "set_user_session": {
      "user": {
        "id": {
          "template": "{{blocks['read_employee_info'].outputs.data.id}}"
        },
        "enterprise_uuid": {
          "template": "{{blocks['read_employee_info'].outputs.data.enterprise_uuid}}"
        },
        "enterprise_name": {
          "template": "{{blocks['read_enterprise_info'].outputs.data.name}}"
        },
        "name": {
          "template": "{{blocks['read_employee_info'].outputs.data.name}}"
        },
        "email": {
          "template": "{{blocks['read_employee_info'].outputs.data.email}}"
        },
        "plan": {
          "template": "{{blocks['read_employee_info'].outputs.data.plan}}"
        }
      }
    }
  }
}
