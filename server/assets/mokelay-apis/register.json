{
  "uuid": "register",
  "alias": "注册接口",
  "method": "POST",
  "request": {
    "body": [
      {
        "key": "enterprise_name",
        "processors": [
          "trim",
          "is_not_null",
          { "processor": "max", "param": [120] }
        ]
      },
      {
        "key": "name",
        "processors": [
          "trim",
          { "processor": "min", "param": [1] },
          { "processor": "max", "param": [120] }
        ]
      },
      {
        "key": "email",
        "processors": [
          "trim",
          "is_not_null",
          "email_check",
          { "processor": "max", "param": [255] }
        ]
      },
      {
        "key": "password",
        "processors": [
          "is_not_null",
          { "processor": "min", "param": [8] },
          { "processor": "max", "param": [128] },
          { "processor": "regex", "param": "/[A-Za-z]/" },
          { "processor": "regex", "param": "/[0-9]/" },
          "hash_make"
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "check_email_duplicate"
    },
    {
      "uuid": "check_email_duplicate",
      "alias": "检查Email是否有重复注册",
      "functionName": "count",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "email",
            "fieldValue": { "template": "{{request.body.email}}" }
          }
        ]
      },
      "outputs": [
        {
          "key": "total",
          "processors": [{ "processor": "eq", "param": [0] }]
        }
      ],
      "nextBlock": "provision_new_user"
    },
    {
      "uuid": "provision_new_user",
      "alias": "执行新用户注册 Fragment",
      "functionName": "executeFragment",
      "inputs": {
        "fragmentUuid": "provision_new_user",
        "params": {
          "enterprise_name": { "template": "{{request.body.enterprise_name}}" },
          "name": { "template": "{{request.body.name}}" },
          "email": { "template": "{{request.body.email}}" },
          "password_hash": { "template": "{{request.body.password}}" }
        }
      },
      "outputs": ["result"],
      "nextBlock": "set_user_session"
    },
    {
      "uuid": "set_user_session",
      "alias": "保存员工信息到Session",
      "functionName": "addSession",
      "inputs": {
        "key": "user",
        "value": { "template": "{{blocks.provision_new_user.outputs.result.user}}" }
      },
      "outputs": [],
      "nextBlock": null
    }
  ],
  "responses": {
    "set_user_session": {
      "user": { "template": "{{blocks.provision_new_user.outputs.result.user}}" }
    }
  }
}
