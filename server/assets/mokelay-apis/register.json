{
  "uuid": "register",
  "alias": "注册接口",
  "method": "POST",
  "request": {
      "body": [
          {
            "key":"name",
            "processors":[
              "trim",
              "is_not_null",
              "email_check",
              {
                "processor":"max",
                "param":[255]
              }
            ]
          },{
            "key":"email",
            "processors":[
              "trim",
              "is_not_null",
              "email_check",
              {
                "processor":"max",
                "param":[255]
              }
            ]
          },{
            "key":"password",
            "processors":[
              "trim",
              "is_not_null",
              "email_check",
              {
                "processor":"max",
                "param":[255]
              }
            ]
          }
      ]
  },
  "blocks": [
      {
          "uuid": "check_email_duplicate",
          "alias": "检查Email是否有重复注册",
          "functionName": "count",
          "inputs": {
              "datasource": "Mokelay",
              "table": "users",
              "conditions": [
                  {
                      "group": false,
                      "conditionType": "EQ",
                      "fieldName": "email",
                      "fieldValue": {
                          "template": "{{request.body.email}}"
                      }
                  }
              ]
          },
          "outputs": [
              {
                "key":"total",
                "processors":[
                  {
                    "processor":"eq",
                    "param":[0]
                  }
                ]
              }
          ]
      },{
          "uuid": "create_user_info",
          "alias": "创建用户信息",
          "functionName": "create",
          "inputs": {
            "datasource": "Mokelay",
            "table": "users",
            "idField": "id",
            "fields": {
              "name": {
                "template": "{{request.body.name}}"
              },
              "email": {
                "template": "{{request.body.email}}"
              },
              "password_hash": {
                "template": "{{request.body.password}}"
              }
            }
          },
          "outputs":[]
      },{

      }
  ],
  "response": {
      "user": {
          "template": ""
      }
  }
}