{
  "uuid": "read_layout_by_uuid",
  "alias": "读取布局接口",
  "method": "GET",
  "request": {
    "query": [
      "uuid"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "functionName": "requireTenantContext",
      "inputs": { "datasource": "Mokelay" },
      "outputs": ["enterpriseUuid"],
      "nextBlock": "read_layout_block"
    },
    {
      "uuid": "read_layout_block",
      "alias": "读取布局 Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "layouts",
        "fields": [
          "uuid",
          "name",
          "layout_json",
          "created_at",
          "updated_at", "enterprise_uuid"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            }
          },
          { "group": false, "conditionType": "EQ", "fieldName": "enterprise_uuid", "fieldValue": { "template": "{{blocks['require_tenant_context'].outputs.enterpriseUuid}}" } }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_layout_block": {
      "layout": {
        "uuid": {
          "template": "{{blocks['read_layout_block'].outputs.data.uuid}}"
        },
        "name": {
          "template": "{{blocks['read_layout_block'].outputs.data.name}}"
        },
        "layoutJson": {
          "template": "{{blocks['read_layout_block'].outputs.data.layout_json}}"
        },
        "createdAt": {
          "template": "{{blocks['read_layout_block'].outputs.data.created_at}}"
        },
        "updatedAt": {
          "template": "{{blocks['read_layout_block'].outputs.data.updated_at}}"
        }
      }
    }
  }
}
