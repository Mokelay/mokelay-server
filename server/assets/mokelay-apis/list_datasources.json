{
  "uuid": "list_datasources",
  "alias": "数据源列表接口",
  "method": "GET",
  "request": {
    "query": [
      "page",
      "pageSize"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "alias": "读取当前企业",
      "functionName": "requireTenantContext",
      "inputs": { "datasource": "Mokelay" },
      "outputs": ["enterpriseUuid"],
      "nextBlock": "list_datasources_block"
    },
    {
      "uuid": "list_datasources_block",
      "alias": "数据源分页 Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "datasources",
        "fields": [
          "id",
          "uuid",
          "alias",
          "description",
          "schema_data"
          ,"enterprise_uuid"
        ],
        "conditions": [{
          "group": false,
          "conditionType": "EQ",
          "fieldName": "enterprise_uuid",
          "fieldValue": { "template": "{{blocks['require_tenant_context'].outputs.enterpriseUuid}}" }
        }],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "orderBy": [
          {
            "fieldName": "id",
            "direction": "DESC"
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "list_datasources_block": {
      "datasources": {
        "template": "{{blocks['list_datasources_block'].outputs.datas}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['list_datasources_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['list_datasources_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['list_datasources_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['list_datasources_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['list_datasources_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['list_datasources_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
