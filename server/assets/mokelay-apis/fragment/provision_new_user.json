{
  "uuid": "provision_new_user",
  "alias": "创建新用户及免费数据源",
  "fragment": true,
  "params": [
    "enterprise_name",
    "name",
    "email",
    "password_hash"
  ],
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "create_enterprise_info"
    },
    {
      "uuid": "create_enterprise_info",
      "alias": "创建企业信息",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "enterprise",
        "idField": "uuid",
        "fields": {
          "name": {
            "template": "{{params.enterprise_name}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "read_enterprise_info"
    },
    {
      "uuid": "read_enterprise_info",
      "alias": "读取创建的企业信息",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "enterprise",
        "fields": [
          "uuid",
          "name"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{blocks.create_enterprise_info.outputs.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": "create_employee_info"
    },
    {
      "uuid": "create_employee_info",
      "alias": "创建员工信息",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "idField": "id",
        "fields": {
          "enterprise_uuid": {
            "template": "{{blocks.create_enterprise_info.outputs.uuid}}"
          },
          "name": {
            "template": "{{params.name}}"
          },
          "email": {
            "template": "{{params.email}}"
          },
          "password_hash": {
            "template": "{{params.password_hash}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "read_employee_info"
    },
    {
      "uuid": "read_employee_info",
      "alias": "读取创建的员工信息",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "fields": [
          "id",
          "enterprise_uuid",
          "name",
          "email",
          "plan"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "id",
            "fieldValue": {
              "template": "{{blocks.create_employee_info.outputs.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": "generate_free_schema_name"
    },
    {
      "uuid": "generate_free_schema_name",
      "alias": "生成企业免费 Schema 名",
      "functionName": "randomId",
      "inputs": {
        "prefix": "e_",
        "length": 5,
        "alphabet": "abcdefghijklmnopqrstuvwxyz0123456789",
        "lowerCase": true
      },
      "outputs": [
        "value"
      ],
      "nextBlock": "assert_free_datasource_uuid_unique"
    },
    {
      "uuid": "assert_free_datasource_uuid_unique",
      "alias": "校验免费数据源 UUID 唯一",
      "functionName": "assertUnique",
      "inputs": {
        "datasource": "Mokelay",
        "table": "datasources",
        "fieldName": "uuid",
        "value": {
          "template": "{{blocks.generate_free_schema_name.outputs.value}}"
        },
        "message": "免费数据源标识已存在，请重试注册。"
      },
      "outputs": [],
      "nextBlock": "create_free_schema"
    },
    {
      "uuid": "create_free_schema",
      "alias": "创建企业免费 Schema",
      "functionName": "createSchema",
      "inputs": {
        "datasource": "MokelayFree",
        "schema": {
          "template": "{{blocks.generate_free_schema_name.outputs.value}}"
        }
      },
      "outputs": [
        "schema",
        {
          "key": "created",
          "processors": [
            {
              "processor": "eq",
              "param": [
                true
              ]
            }
          ]
        },
        "exists"
      ],
      "nextBlock": "create_free_datasource"
    },
    {
      "uuid": "create_free_datasource",
      "alias": "创建企业免费数据源记录",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "datasources",
        "idField": "id",
        "fields": {
          "uuid": {
            "template": "{{blocks.create_free_schema.outputs.schema}}"
          },
          "alias": "Mokelay免费数据源",
          "description": "限制5个模型",
          "enterprise_uuid": {
            "template": "{{blocks.create_enterprise_info.outputs.uuid}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": null
    }
  ],
  "response": {
    "user": {
      "id": {
        "template": "{{blocks.read_employee_info.outputs.data.id}}"
      },
      "enterprise_uuid": {
        "template": "{{blocks.read_employee_info.outputs.data.enterprise_uuid}}"
      },
      "enterprise_name": {
        "template": "{{blocks.read_enterprise_info.outputs.data.name}}"
      },
      "name": {
        "template": "{{blocks.read_employee_info.outputs.data.name}}"
      },
      "email": {
        "template": "{{blocks.read_employee_info.outputs.data.email}}"
      },
      "plan": {
        "template": "{{blocks.read_employee_info.outputs.data.plan}}"
      }
    },
    "free_datasource_uuid": {
      "template": "{{blocks.create_free_schema.outputs.schema}}"
    }
  }
}
