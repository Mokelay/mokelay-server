{
  "uuid": "read_bingx_wallet_by_id",
  "alias": "读取 BingX 钱包接口",
  "method": "GET",
  "request": {
    "query": ["id"]
  },
  "blocks": [
    {
      "uuid": "read_wallet_block",
      "alias": "读取钱包Block",
      "functionName": "read",
      "inputs": {
        "datasource": "BingX",
        "table": "wallets",
        "fields": ["id", "chain_id", "address", "label", "wallet_type", "first_seen_at", "last_seen_at", "created_at", "updated_at"],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "id",
            "fieldValue": {
              "template": "{{request.query.id}}"
            }
          }
        ]
      },
      "outputs": ["data"]
    }
  ],
  "response": {
    "wallet": {
      "template": "{{blocks['read_wallet_block'].outputs.data}}"
    }
  }
}
