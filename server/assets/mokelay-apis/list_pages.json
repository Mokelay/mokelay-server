{
  "uuid": "list_pages",
  "alias": "页面列表接口",
  "method": "GET",
  "request": {
    "query": [
      "page",
      "pageSize",
      {
        "key": "uuid",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "name",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "subPage",
        "processors": [
          "boolean_value"
        ]
      },
      {
        "key": "created_at_begin",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "created_at_end",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "appUuid",
        "processors": ["trim", "is_not_null"]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "require_tenant_context"
    },
    {
      "uuid": "require_tenant_context",
      "functionName": "requireTenantContext",
      "inputs": {
        "datasource": "Mokelay",
        "appUuid": { "template": "{{request.query.appUuid}}" },
        "requireApp": true
      },
      "outputs": ["enterpriseUuid", "appUuid"],
      "nextBlock": "normalize_page_uuid_filter_block"
    },
    {
      "uuid": "normalize_page_uuid_filter_block",
      "alias": "规范化可选页面标识筛选",
      "functionName": "normalizePageUuid",
      "inputs": {
        "uuid": {
          "template": "{{request.query.uuid}}"
        },
        "optional": true
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "list_pages_block"
    },
    {
      "uuid": "list_pages_block",
      "alias": "页面分页Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "pages",
        "fields": [
          "uuid",
          "name",
          "blocks",
          "app_uuid",
          "layout_uuid",
          "sub_page",
          "quotes",
          "dependencies",
          "created_at",
          "updated_at"
          ,"enterprise_uuid"
        ],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "enterprise_uuid",
            "fieldValue": { "template": "{{blocks['require_tenant_context'].outputs.enterpriseUuid}}" }
          },
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "app_uuid",
            "fieldValue": { "template": "{{blocks['require_tenant_context'].outputs.appUuid}}" }
          },
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{blocks['normalize_page_uuid_filter_block'].outputs.uuid}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "name",
            "fieldValue": {
              "template": "{{request.query.name}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "sub_page",
            "fieldValue": {
              "template": "{{request.query.subPage}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "GE",
            "fieldName": "created_at",
            "fieldValue": {
              "template": "{{request.query.created_at_begin}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "LE",
            "fieldName": "created_at",
            "fieldValue": {
              "template": "{{request.query.created_at_end}}"
            },
            "optional": true
          }
        ],
        "orderBy": [
          {
            "fieldName": "updated_at",
            "direction": "DESC"
          },
          {
            "fieldName": "created_at",
            "direction": "DESC"
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": "normalize_page_rows_block"
    },
    {
      "uuid": "normalize_page_rows_block",
      "alias": "标准化页面关系字段",
      "functionName": "normalizePageRows",
      "inputs": {
        "rows": { "template": "{{blocks['list_pages_block'].outputs.datas}}" },
        "page": { "template": "{{blocks['list_pages_block'].outputs.page}}" },
        "pageSize": { "template": "{{blocks['list_pages_block'].outputs.pageSize}}" },
        "total": { "template": "{{blocks['list_pages_block'].outputs.total}}" },
        "totalPages": { "template": "{{blocks['list_pages_block'].outputs.totalPages}}" },
        "hasPreviousPage": { "template": "{{blocks['list_pages_block'].outputs.hasPreviousPage}}" },
        "hasNextPage": { "template": "{{blocks['list_pages_block'].outputs.hasNextPage}}" }
      },
      "outputs": ["pages", "page", "pageSize", "total", "totalPages", "hasPreviousPage", "hasNextPage"],
      "nextBlock": null
    }
  ],
  "responses": {
    "normalize_page_rows_block": {
      "pages": {
        "template": "{{blocks['normalize_page_rows_block'].outputs.pages}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['normalize_page_rows_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['normalize_page_rows_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['normalize_page_rows_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['normalize_page_rows_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['normalize_page_rows_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['normalize_page_rows_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
