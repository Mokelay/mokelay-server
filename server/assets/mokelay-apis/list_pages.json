{
  "uuid": "list_pages",
  "alias": "页面列表接口",
  "method": "GET",
  "request": {
    "query": [
      "page",
      "pageSize",
      {
        "key": "uuid",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "name",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "created_at_begin",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "created_at_end",
        "processors": [
          "trim"
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "list_pages_block"
    },
    {
      "uuid": "list_pages_block",
      "alias": "页面分页Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "pages",
        "fields": [
          "uuid",
          "name",
          "blocks",
          "created_at",
          "updated_at"
        ],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{request.query.uuid}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "name",
            "fieldValue": {
              "template": "{{request.query.name}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "GE",
            "fieldName": "created_at",
            "fieldValue": {
              "template": "{{request.query.created_at_begin}}"
            },
            "optional": true
          },
          {
            "group": false,
            "conditionType": "LE",
            "fieldName": "created_at",
            "fieldValue": {
              "template": "{{request.query.created_at_end}}"
            },
            "optional": true
          }
        ],
        "orderBy": [
          {
            "fieldName": "updated_at",
            "direction": "DESC"
          },
          {
            "fieldName": "created_at",
            "direction": "DESC"
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "list_pages_block": {
      "pages": {
        "template": "{{blocks['list_pages_block'].outputs.datas}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['list_pages_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['list_pages_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['list_pages_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['list_pages_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['list_pages_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['list_pages_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
