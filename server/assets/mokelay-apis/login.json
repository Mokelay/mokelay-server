{
  "uuid": "login",
  "alias": "登录接口",
  "method": "POST",
  "request": {
    "body": [
      {
        "key": "email",
        "processors": [
          "trim",
          "is_not_null",
          "email_check",
          {
            "processor": "max",
            "param": [
              255
            ]
          }
        ]
      },
      {
        "key": "password",
        "processors": [
          "is_not_null",
          {
            "processor": "min",
            "param": [
              1
            ]
          }
        ]
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "read_employee_info"
    },
    {
      "uuid": "read_employee_info",
      "alias": "按邮箱读取员工信息",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "employees",
        "fields": [
          "id",
          "enterprise_uuid",
          "name",
          "email",
          "plan",
          "password_hash"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "email",
            "fieldValue": {
              "template": "{{request.body.email}}"
            }
          }
        ]
      },
      "outputs": [
        {
          "key": "data",
          "processors": [
            "is_not_null"
          ]
        }
      ],
      "nextBlock": "check_employee_password"
    },
    {
      "uuid": "check_employee_password",
      "alias": "校验密码控制器",
      "functionName": "if_controller",
      "type": "controller",
      "inputs": {
        "value": {
          "template": "{{blocks['read_employee_info'].outputs.data.password_hash}}",
          "processors": [
            {
              "processor": "hash_check",
              "param": [
                {
                  "template": "{{request.body.password}}"
                }
              ]
            }
          ]
        }
      },
      "nodes": [
        {
          "uuid": "password_check_true_node",
          "alias": "密码校验通过",
          "value": true,
          "nextBlock": "read_enterprise_info"
        },
        {
          "uuid": "password_check_false_node",
          "alias": "密码校验失败",
          "value": false,
          "nextBlock": null
        }
      ]
    },
    {
      "uuid": "read_enterprise_info",
      "alias": "读取员工企业信息",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "enterprise",
        "fields": [
          "uuid",
          "name"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{blocks['read_employee_info'].outputs.data.enterprise_uuid}}"
            }
          }
        ]
      },
      "outputs": [
        {
          "key": "data",
          "processors": [
            "is_not_null"
          ]
        }
      ],
      "nextBlock": "set_user_session"
    },
    {
      "uuid": "set_user_session",
      "alias": "保存员工信息到Session",
      "functionName": "addSession",
      "inputs": {
        "key": "user",
        "value": {
          "id": {
            "template": "{{blocks['read_employee_info'].outputs.data.id}}"
          },
          "enterprise_uuid": {
            "template": "{{blocks['read_employee_info'].outputs.data.enterprise_uuid}}"
          },
          "enterprise_name": {
            "template": "{{blocks['read_enterprise_info'].outputs.data.name}}"
          },
          "name": {
            "template": "{{blocks['read_employee_info'].outputs.data.name}}"
          },
          "email": {
            "template": "{{blocks['read_employee_info'].outputs.data.email}}"
          },
          "plan": {
            "template": "{{blocks['read_employee_info'].outputs.data.plan}}"
          }
        }
      },
      "nextBlock": null
    }
  ],
  "responses": {
    "password_check_false_node": {
      "user": null
    },
    "set_user_session": {
      "user": {
        "id": {
          "template": "{{blocks['read_employee_info'].outputs.data.id}}"
        },
        "enterprise_uuid": {
          "template": "{{blocks['read_employee_info'].outputs.data.enterprise_uuid}}"
        },
        "enterprise_name": {
          "template": "{{blocks['read_enterprise_info'].outputs.data.name}}"
        },
        "name": {
          "template": "{{blocks['read_employee_info'].outputs.data.name}}"
        },
        "email": {
          "template": "{{blocks['read_employee_info'].outputs.data.email}}"
        },
        "plan": {
          "template": "{{blocks['read_employee_info'].outputs.data.plan}}"
        }
      }
    }
  }
}
