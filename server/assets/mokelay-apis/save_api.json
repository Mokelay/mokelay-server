{
  "uuid": "save_api",
  "alias": "保存 API 接口",
  "method": "POST",
  "request": {
    "body": [
      "uuid",
      "name",
      {
        "key": "method"
      },
      {
        "key": "fragment"
      },
      "status",
      "apiJson",
      {
        "key": "layout"
      },
      {
        "key": "originalUuid"
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "validate_api_definition_block"
    },
    {
      "uuid": "validate_api_definition_block",
      "alias": "校验 API/Fragment 定义",
      "functionName": "validateApiDefinition",
      "inputs": {
        "datasource": "Mokelay",
        "uuid": {
          "template": "{{request.body.uuid}}"
        },
        "method": {
          "template": "{{request.body.method}}"
        },
        "fragment": {
          "template": "{{request.body.fragment}}"
        },
        "status": {
          "template": "{{request.body.status}}"
        },
        "apiJson": {
          "template": "{{request.body.apiJson}}"
        },
        "originalUuid": {
          "template": "{{request.body.originalUuid}}"
        }
      },
      "outputs": [
        "method",
        "fragment"
      ],
      "nextBlock": "assert_unique_api_uuid_block"
    },
    {
      "uuid": "assert_unique_api_uuid_block",
      "alias": "校验 API 标识唯一",
      "functionName": "assertUnique",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis",
        "fieldName": "uuid",
        "value": {
          "template": "{{request.body.uuid}}"
        },
        "ignoreField": "uuid",
        "ignoreValue": {
          "template": "{{request.body.originalUuid}}"
        },
        "message": "API 标识已存在。"
      },
      "nextBlock": "publish_api_json_controller"
    },
    {
      "uuid": "publish_api_json_controller",
      "alias": "按状态决定是否发布 API DSL",
      "functionName": "switch_controller",
      "type": "controller",
      "inputs": {
        "value": {
          "template": "{{request.body.status}}"
        },
        "dataType": "string"
      },
      "nodes": [
        {
          "uuid": "publish_api_json_node",
          "alias": "已发布状态",
          "value": "published",
          "nextBlock": "publish_fragment_controller"
        },
        {
          "uuid": "skip_api_json_publish_node",
          "alias": "非发布状态",
          "type": "DEFAULT",
          "nextBlock": "save_api_block"
        }
      ]
    },
    {
      "uuid": "publish_fragment_controller",
      "alias": "Fragment 仅发布到数据库",
      "functionName": "if_controller",
      "type": "controller",
      "inputs": {
        "value": {
          "template": "{{blocks['validate_api_definition_block'].outputs.fragment}}"
        }
      },
      "nodes": [
        {
          "uuid": "skip_fragment_r2_publish_node",
          "alias": "Fragment 不写入 R2",
          "value": true,
          "nextBlock": "save_api_block"
        },
        {
          "uuid": "publish_endpoint_r2_node",
          "alias": "普通 API 写入 R2",
          "value": false,
          "nextBlock": "publish_api_json_to_r2_block"
        }
      ]
    },
    {
      "uuid": "publish_api_json_to_r2_block",
      "alias": "发布 API DSL 到 R2 Block",
      "functionName": "saveJsonToR2",
      "inputs": {
        "directory": {
          "template": "{{request.body.status}}",
          "processors": [
            {
              "processor": "env_value",
              "param": "MOKELAY_APIS_R2_PREFIX"
            }
          ]
        },
        "fileName": {
          "template": "{{request.body.uuid}}.json"
        },
        "data": {
          "template": "{{request.body.apiJson}}",
          "processors": [
            {
              "processor": "api_json_when_published",
              "param": {
                "uuid": {
                  "template": "{{request.body.uuid}}"
                },
                "status": {
                  "template": "{{request.body.status}}"
                }
              }
            }
          ]
        }
      },
      "nextBlock": "save_api_block"
    },
    {
      "uuid": "save_api_block",
      "alias": "保存 API Block",
      "functionName": "upsert",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis",
        "idField": "uuid",
        "fields": {
          "uuid": {
            "template": "{{request.body.uuid}}"
          },
          "name": {
            "template": "{{request.body.name}}"
          },
          "method": {
            "template": "{{blocks['validate_api_definition_block'].outputs.method}}"
          },
          "fragment": {
            "template": "{{blocks['validate_api_definition_block'].outputs.fragment}}"
          },
          "status": {
            "template": "{{request.body.status}}"
          },
          "api_json": {
            "template": "{{request.body.apiJson}}"
          },
          "layout": {
            "template": "{{request.body.layout}}",
            "processors": [
              {
                "processor": "default_value",
                "param": {}
              }
            ]
          },
          "updated_at": {
            "template": "{{now}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "create_api_snapshot_block"
    },
    {
      "uuid": "create_api_snapshot_block",
      "alias": "创建 API 快照 Block",
      "functionName": "create",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis_snapshot",
        "idField": "id",
        "fields": {
          "api_uuid": {
            "template": "{{blocks['save_api_block'].outputs.uuid}}"
          },
          "name": {
            "template": "{{request.body.name}}"
          },
          "method": {
            "template": "{{blocks['validate_api_definition_block'].outputs.method}}"
          },
          "fragment": {
            "template": "{{blocks['validate_api_definition_block'].outputs.fragment}}"
          },
          "status": {
            "template": "{{request.body.status}}"
          },
          "api_json": {
            "template": "{{request.body.apiJson}}"
          }
        }
      },
      "outputs": [
        "uuid"
      ],
      "nextBlock": "read_api_block"
    },
    {
      "uuid": "read_api_block",
      "alias": "读取保存后的 API Block",
      "functionName": "read",
      "inputs": {
        "datasource": "Mokelay",
        "table": "apis",
        "fields": [
          "uuid",
          "name",
          "method",
          "fragment",
          "status",
          "api_json",
          "layout",
          "created_at",
          "updated_at"
        ],
        "conditions": [
          {
            "group": false,
            "conditionType": "EQ",
            "fieldName": "uuid",
            "fieldValue": {
              "template": "{{blocks['save_api_block'].outputs.uuid}}"
            }
          }
        ]
      },
      "outputs": [
        "data"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "read_api_block": {
      "api": {
        "uuid": {
          "template": "{{blocks['read_api_block'].outputs.data.uuid}}"
        },
        "name": {
          "template": "{{blocks['read_api_block'].outputs.data.name}}"
        },
        "method": {
          "template": "{{blocks['read_api_block'].outputs.data.method}}"
        },
        "fragment": {
          "template": "{{blocks['read_api_block'].outputs.data.fragment}}"
        },
        "status": {
          "template": "{{blocks['read_api_block'].outputs.data.status}}"
        },
        "apiJson": {
          "template": "{{blocks['read_api_block'].outputs.data.api_json}}"
        },
        "layout": {
          "template": "{{blocks['read_api_block'].outputs.data.layout}}"
        },
        "createdAt": {
          "template": "{{blocks['read_api_block'].outputs.data.created_at}}"
        },
        "updatedAt": {
          "template": "{{blocks['read_api_block'].outputs.data.updated_at}}"
        }
      }
    }
  }
}
