{
  "uuid": "list_block_component_docs",
  "alias": "Block 组件文档列表接口",
  "method": "GET",
  "request": {
    "query": [
      "page",
      "pageSize"
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "list_block_docs_block"
    },
    {
      "uuid": "list_block_docs_block",
      "alias": "Block 文档分页 Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "block_component_docs",
        "fields": [
          "id",
          "uuid",
          "block_type",
          "display_name",
          "category",
          "source_kind",
          "source_file",
          "description",
          "status",
          "toolbox",
          "initial_props",
          "property_schema",
          "event_schema",
          "method_schema",
          "data_fields_schema",
          "examples",
          "source_refs",
          "raw_meta",
          "created_at",
          "updated_at"
        ],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "orderBy": [
          {
            "fieldName": "source_kind",
            "direction": "ASC"
          },
          {
            "fieldName": "category",
            "direction": "ASC"
          },
          {
            "fieldName": "block_type",
            "direction": "ASC"
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "list_block_docs_block": {
      "docs": {
        "template": "{{blocks['list_block_docs_block'].outputs.datas}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['list_block_docs_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['list_block_docs_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['list_block_docs_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['list_block_docs_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['list_block_docs_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['list_block_docs_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
