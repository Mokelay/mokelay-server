{
  "uuid": "list_block_component_docs",
  "alias": "Block 组件文档列表接口",
  "method": "GET",
  "request": {
    "query": [
      {
        "key": "page",
        "processors": [
          {
            "processor": "default_value",
            "param": 1
          }
        ]
      },
      "pageSize",
      {
        "key": "blockType",
        "processors": [
          "trim"
        ]
      },
      {
        "key": "status"
      },
      {
        "key": "sourceKind"
      },
      {
        "key": "category"
      },
      {
        "key": "editorEnabled"
      },
      {
        "key": "toolboxVisible"
      },
      {
        "key": "editorBlock"
      }
    ]
  },
  "blocks": [
    {
      "uuid": "starter",
      "nextBlock": "list_block_docs_block"
    },
    {
      "uuid": "list_block_docs_block",
      "alias": "Block 文档分页 Block",
      "functionName": "page",
      "inputs": {
        "datasource": "Mokelay",
        "table": "docs_client_block",
        "fields": [
          "id",
          "uuid",
          "block_type",
          "display_name",
          "category",
          "source_kind",
          "source_package",
          "source_file",
          "component_name",
          "tool_symbol",
          "description",
          "status",
          "editor_enabled",
          "toolbox_visible",
          "editor_block",
          "sort_order",
          "registration",
          "toolbox",
          "initial_props",
          "default_data",
          "property_schema",
          "event_schema",
          "method_schema",
          "data_fields_schema",
          "save_schema",
          "examples",
          "source_refs",
          "raw_meta",
          "created_at",
          "updated_at"
        ],
        "page": {
          "template": "{{request.query.page}}"
        },
        "pageSize": {
          "template": "{{request.query.pageSize}}"
        },
        "orderBy": [
          {
            "fieldName": "sort_order",
            "direction": "ASC"
          },
          {
            "fieldName": "category",
            "direction": "ASC"
          },
          {
            "fieldName": "block_type",
            "direction": "ASC"
          }
        ],
        "conditions": [
          {
            "group": false,
            "optional": true,
            "conditionType": "LIKE",
            "fieldName": "block_type",
            "fieldValue": {
              "template": "{{request.query.blockType}}"
            }
          },
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "status",
            "fieldValue": {
              "template": "{{request.query.status}}"
            }
          },
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "source_kind",
            "fieldValue": {
              "template": "{{request.query.sourceKind}}"
            }
          },
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "category",
            "fieldValue": {
              "template": "{{request.query.category}}"
            }
          },
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "editor_enabled",
            "fieldValue": {
              "template": "{{request.query.editorEnabled}}"
            }
          },
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "toolbox_visible",
            "fieldValue": {
              "template": "{{request.query.toolboxVisible}}"
            }
          },
          {
            "group": false,
            "optional": true,
            "conditionType": "EQ",
            "fieldName": "editor_block",
            "fieldValue": {
              "template": "{{request.query.editorBlock}}"
            }
          }
        ]
      },
      "outputs": [
        "datas",
        "total",
        "totalPages",
        "page",
        "pageSize",
        "hasPreviousPage",
        "hasNextPage"
      ],
      "nextBlock": null
    }
  ],
  "responses": {
    "list_block_docs_block": {
      "docs": {
        "template": "{{blocks['list_block_docs_block'].outputs.datas}}"
      },
      "pagination": {
        "page": {
          "template": "{{blocks['list_block_docs_block'].outputs.page}}"
        },
        "pageSize": {
          "template": "{{blocks['list_block_docs_block'].outputs.pageSize}}"
        },
        "total": {
          "template": "{{blocks['list_block_docs_block'].outputs.total}}"
        },
        "totalPages": {
          "template": "{{blocks['list_block_docs_block'].outputs.totalPages}}"
        },
        "hasPreviousPage": {
          "template": "{{blocks['list_block_docs_block'].outputs.hasPreviousPage}}"
        },
        "hasNextPage": {
          "template": "{{blocks['list_block_docs_block'].outputs.hasNextPage}}"
        }
      }
    }
  }
}
