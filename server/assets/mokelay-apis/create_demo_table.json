{
  "uuid": "create_demo_table",
  "alias": "创建DEMOJSON",
  "method": "POST",
  "request": {
    "body": ["name"]
  },
  "blocks": [
    {
      "uuid": "ax2e",
      "alias": "添加Block",
      "functionName": "create",
      "inputs": {
        "datasource": "Demo",
        "table": "demo_table",
        "idField": "id",
        "fields": {
          "name": {
            "template": "{{request.body.name}}"
          }
        }
      },
      "outputs": ["uuid"]
    }
  ],
  "response": {
    "id": {
      "template": "{{blocks['ax2e'].outputs.uuid}}"
    }
  }
}
